+
+  // ---- Analytics resilience (PostHog failures) ----
+  describe('analytics resilience', () => {
+    it('handleSubscriptionCreated succeeds when PostHog throws', async () => {
+      mockResolveTierFromPriceId.mockReturnValue('pass');
+      setupSelect([]);
+      setupUpdate();
