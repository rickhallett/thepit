+        arxivId: '2305.14325',
+        arxivUrl: 'https://arxiv.org/abs/2305.14325',
+        title: 'Test Paper',
+        authors: 'Author A',
+        abstract: 'Abstract text',
+        justification: 'Relevant because...',
