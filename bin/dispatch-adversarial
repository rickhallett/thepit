#!/usr/bin/env bash
set -euo pipefail

# Dispatch adversarial review prompts to 3 model families (9 prompts x 3 models = 27)
# Usage: bin/dispatch-adversarial [--model codex|grok|gemini|claude] [--prompt N] [--dry-run]
#
# Default: dispatches all 27. Use flags to filter.
# Responses are saved to data/alley/bootcamp-adversarial/{model}/prompt-{N}-{name}-response.md
# After collection: uv run bin/assemble-adversarial

BASE="data/alley/bootcamp-adversarial"
TIMEOUT=600  # 10 min per dispatch - these are large prompts
FILTER_MODEL=""
FILTER_PROMPT=""
DRY_RUN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)   FILTER_MODEL="$2"; shift 2 ;;
        --prompt)  FILTER_PROMPT="$2"; shift 2 ;;
        --dry-run) DRY_RUN=true; shift ;;
        *)         echo "Unknown arg: $1"; exit 1 ;;
    esac
done

MODELS=("codex" "gemini" "claude")
PROMPTS=(1 2 3 4 5 6 7 8 9)
NAMES=(
    [1]="repackaging"
    [2]="depth-test"
    [3]="accuracy-audit"
    [4]="irreplaceability"
    [5]="audience-problem"
    [6]="completeness-trap"
    [7]="slop-detector"
    [8]="pedagogy-review"
    [9]="so-what-test"
)

dispatch_claude() {
    local prompt_file="$1"
    local out_file="$2"
    # claude -p takes prompt as argument; --allowedTools Read lets it read files
    timeout "$TIMEOUT" claude -p "$(cat "$prompt_file")" \
        --allowedTools "Read" \
        > "$out_file" 2>&1
}

dispatch_codex() {
    local prompt_file="$1"
    local out_file="$2"
    # codex exec reads from stdin when prompt is -
    timeout "$TIMEOUT" codex exec --sandbox read-only \
        - < "$prompt_file" \
        > "$out_file" 2>&1
}

dispatch_gemini() {
    local prompt_file="$1"
    local out_file="$2"
    # gemini -p takes prompt as argument; -y auto-accepts
    timeout "$TIMEOUT" gemini -y -p \
        "$(cat "$prompt_file")" \
        > "$out_file" 2>&1
}

total=0
launched=0
skipped=0
failed=0

for model in "${MODELS[@]}"; do
    [[ -n "$FILTER_MODEL" && "$model" != "$FILTER_MODEL" ]] && continue

    # Map model to dispatch directory (codex dispatches use codex dir, claude uses grok dir for the slot)
    # The dispatch files are labelled by slot, not by model CLI
    # codex -> codex dir, gemini -> gemini dir, claude -> grok dir (3rd model slot)
    case "$model" in
        codex)  dispatch_dir="$BASE/codex" ;;
        gemini) dispatch_dir="$BASE/gemini" ;;
        claude) dispatch_dir="$BASE/grok" ;;  # claude fills the grok slot
    esac

    for num in "${PROMPTS[@]}"; do
        [[ -n "$FILTER_PROMPT" && "$num" != "$FILTER_PROMPT" ]] && continue

        name="${NAMES[$num]}"
        prompt_file="$dispatch_dir/prompt-${num}-${name}.md"
        response_file="$dispatch_dir/prompt-${num}-${name}-response.md"
        total=$((total + 1))

        if [[ ! -f "$prompt_file" ]]; then
            echo "SKIP: $prompt_file not found"
            skipped=$((skipped + 1))
            continue
        fi

        if [[ -f "$response_file" ]]; then
            echo "SKIP: $response_file already exists"
            skipped=$((skipped + 1))
            continue
        fi

        size=$(wc -c < "$prompt_file")
        echo "DISPATCH: $model prompt-$num ($name) [${size} bytes]"

        if $DRY_RUN; then
            echo "  (dry run - skipping)"
            continue
        fi

        case "$model" in
            claude) dispatch_claude "$prompt_file" "$response_file" &;;
            codex)  dispatch_codex  "$prompt_file" "$response_file" &;;
            gemini) dispatch_gemini "$prompt_file" "$response_file" &;;
        esac

        launched=$((launched + 1))

        # Throttle: max 3 concurrent per model to avoid rate limits
        if (( launched % 3 == 0 )); then
            echo "  -- waiting for batch of 3 to complete --"
            wait
        fi
    done
done

# Wait for any remaining
if ! $DRY_RUN && (( launched > 0 )); then
    echo ""
    echo "Waiting for remaining $((launched % 3)) dispatches..."
    wait
fi

echo ""
echo "=== Dispatch Summary ==="
echo "Total:    $total"
echo "Launched: $launched"
echo "Skipped:  $skipped"
echo ""
echo "Responses will be at: $BASE/{model}/prompt-{N}-{name}-response.md"
echo "Run 'uv run bin/assemble-adversarial' to analyse convergence."
