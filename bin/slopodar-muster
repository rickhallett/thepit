#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml", "rich"]
# ///
"""
slopodar-muster - Human confidence rating for single-model new category proposals.

Cycles through proposals one by one in a Rich panel. Operator provides a
confidence rating (0-10) or skips (enter). Rated proposals are written to
file immediately and excluded from future runs.

Usage:
    slopodar-muster [--model claude|gemini|grok] [--min-examples N]

Data:    data/sweep/aggregate.yaml
Scores:  data/sweep/muster-scores.yaml
"""

import sys
from pathlib import Path

import yaml
from rich.console import Console
from rich.panel import Panel
from rich.table import Table
from rich.text import Text
from rich import box

REPO_ROOT = Path(__file__).resolve().parent.parent
AGGREGATE_PATH = REPO_ROOT / "data" / "sweep" / "aggregate.yaml"
SCORES_PATH = REPO_ROOT / "data" / "sweep" / "muster-scores.yaml"

console = Console()


def load_aggregate() -> dict:
    with open(AGGREGATE_PATH) as f:
        return yaml.safe_load(f)


def load_scores() -> dict:
    if SCORES_PATH.exists():
        with open(SCORES_PATH) as f:
            data = yaml.safe_load(f)
            return data if isinstance(data, dict) else {}
    return {}


def save_scores(scores: dict) -> None:
    SCORES_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(SCORES_PATH, "w") as f:
        yaml.dump(scores, f, default_flow_style=False, sort_keys=False,
                  allow_unicode=True, width=120)


def build_proposals(agg: dict, model_filter: str | None = None,
                    min_examples: int = 0) -> list[dict]:
    """Extract single-model proposals with their details."""
    conv = agg.get("new_category_convergence", {})
    details = agg.get("new_category_details", {})

    proposals = []
    for name, data in conv.items():
        if data["model_count"] != 1:
            continue
        model = data["proposed_by"][0]
        if model_filter and model != model_filter:
            continue

        detail_list = details.get(name, [])
        # Count examples across all detail entries
        example_count = sum(
            len(d.get("examples", []) or [])
            for d in detail_list if isinstance(d, dict)
        )
        if example_count < min_examples:
            continue

        proposals.append({
            "name": name,
            "model": model,
            "details": detail_list,
        })

    return proposals


def render_proposal(proposal: dict, index: int, total: int,
                    remaining: int) -> Panel:
    """Render a single proposal as a Rich panel."""
    name = proposal["name"]
    model = proposal["model"]
    details = proposal["details"]

    # Build content
    parts = []

    # Header info
    parts.append(f"[bold cyan]Model:[/bold cyan] {model}")
    parts.append(f"[bold cyan]Progress:[/bold cyan] {index}/{total} "
                 f"([yellow]{remaining} remaining[/yellow])")
    parts.append("")

    for i, d in enumerate(details):
        if not isinstance(d, dict):
            continue

        definition = d.get("definition", "")
        mechanism = d.get("mechanism", "")
        distinct_from = d.get("distinct_from", "")
        chunk = d.get("_chunk", "?")

        if definition:
            parts.append(f"[bold]Definition:[/bold] {definition}")
        if mechanism:
            parts.append(f"[bold]Mechanism:[/bold] {mechanism}")
        if distinct_from:
            parts.append(f"[bold]Distinct from:[/bold] {distinct_from}")

        examples = d.get("examples", [])
        if examples and isinstance(examples, list):
            parts.append("")
            parts.append(f"[bold]Examples ({len(examples)}):[/bold]")
            for j, ex in enumerate(examples):
                if not isinstance(ex, dict):
                    continue
                file_ref = ex.get("file", "?")
                quote = ex.get("quote", "")
                explanation = ex.get("explanation", "")
                parts.append(f"  [dim]{j+1}. {file_ref}[/dim]")
                if quote:
                    # Truncate long quotes
                    q = quote if len(quote) < 200 else quote[:197] + "..."
                    parts.append(f"     [italic]\"{q}\"[/italic]")
                if explanation:
                    e = explanation if len(explanation) < 300 else explanation[:297] + "..."
                    parts.append(f"     {e}")

        parts.append(f"  [dim](chunk: {chunk})[/dim]")

        if i < len(details) - 1:
            parts.append("")

    content = "\n".join(parts)
    return Panel(
        content,
        title=f"[bold white]{name}[/bold white]",
        border_style="blue",
        box=box.ROUNDED,
        padding=(1, 2),
    )


def render_summary(scores: dict) -> None:
    """Show summary of all scored proposals."""
    if not scores:
        console.print("[dim]No scores recorded yet.[/dim]")
        return

    # Group by score
    by_score: dict[int, list[str]] = {}
    skipped = []
    for name, data in scores.items():
        score = data.get("score")
        if score is None:
            skipped.append(name)
        else:
            by_score.setdefault(score, []).append(name)

    table = Table(title="Muster Scores", box=box.SIMPLE_HEAVY)
    table.add_column("Score", style="bold", width=6)
    table.add_column("Count", width=6)
    table.add_column("Proposals", style="dim")

    for s in range(10, -1, -1):
        names = by_score.get(s, [])
        if names:
            table.add_row(
                str(s),
                str(len(names)),
                ", ".join(sorted(names)[:5]) + ("..." if len(names) > 5 else ""),
            )

    console.print(table)

    total_scored = sum(len(v) for v in by_score.values())
    total_skipped = len(skipped)
    console.print(f"\n[bold]Scored:[/bold] {total_scored}  "
                  f"[bold]Skipped:[/bold] {total_skipped}  "
                  f"[bold]Total:[/bold] {total_scored + total_skipped}")

    # High-confidence proposals (7+)
    high = []
    for s in range(10, 6, -1):
        high.extend((name, s) for name in by_score.get(s, []))
    if high:
        console.print(f"\n[bold green]High confidence (7+): {len(high)}[/bold green]")
        for name, s in sorted(high, key=lambda x: -x[1]):
            console.print(f"  [{s}] {name}")


def main() -> None:
    args = sys.argv[1:]

    # Parse args
    model_filter = None
    min_examples = 0
    show_summary = False
    i = 0
    while i < len(args):
        if args[i] == "--model" and i + 1 < len(args):
            model_filter = args[i + 1]
            i += 2
        elif args[i] == "--min-examples" and i + 1 < len(args):
            min_examples = int(args[i + 1])
            i += 2
        elif args[i] == "--summary":
            show_summary = True
            i += 1
        elif args[i] in ("-h", "--help"):
            print(__doc__)
            sys.exit(0)
        else:
            i += 1

    # Load data
    if not AGGREGATE_PATH.exists():
        console.print("[red]ERROR: aggregate.yaml not found. Run slopodar-sweep aggregate first.[/red]")
        sys.exit(1)

    agg = load_aggregate()
    scores = load_scores()

    if show_summary:
        render_summary(scores)
        return

    proposals = build_proposals(agg, model_filter, min_examples)

    # Filter out already-scored
    unscored = [p for p in proposals if p["name"] not in scores]

    total = len(proposals)
    remaining = len(unscored)

    if remaining == 0:
        console.print(Panel(
            f"[green]All {total} proposals have been scored or skipped.[/green]\n\n"
            f"Run with [bold]--summary[/bold] to see results.",
            title="Muster Complete",
            border_style="green",
        ))
        render_summary(scores)
        return

    console.print(Panel(
        f"[bold]{remaining}[/bold] proposals remaining out of {total} total.\n"
        f"{'Model filter: ' + model_filter if model_filter else 'All models.'}\n\n"
        f"[bold]Rate 0-10[/bold] or [bold]Enter[/bold] to skip.\n"
        f"[bold]q[/bold] to quit (progress is saved after every rating).",
        title="Slopodar Muster",
        border_style="yellow",
    ))

    scored_this_session = 0
    skipped_this_session = 0

    for idx, proposal in enumerate(unscored, 1):
        name = proposal["name"]

        console.print()
        console.print(render_proposal(proposal, idx, remaining, remaining - idx + 1))

        # Get input
        while True:
            try:
                raw = console.input("[bold]Score (0-10 / enter=skip / q=quit):[/bold] ")
            except (EOFError, KeyboardInterrupt):
                console.print("\n[yellow]Session ended.[/yellow]")
                console.print(f"Scored: {scored_this_session}, Skipped: {skipped_this_session}")
                return

            raw = raw.strip()

            if raw.lower() == "q":
                console.print(f"\n[yellow]Quit. Scored: {scored_this_session}, "
                              f"Skipped: {skipped_this_session}[/yellow]")
                return

            if raw == "":
                # Skip
                scores[name] = {
                    "score": None,
                    "model": proposal["model"],
                    "status": "skipped",
                }
                save_scores(scores)
                skipped_this_session += 1
                console.print(f"  [dim]Skipped {name}[/dim]")
                break

            try:
                score = int(raw)
                if 0 <= score <= 10:
                    scores[name] = {
                        "score": score,
                        "model": proposal["model"],
                        "status": "rated",
                    }
                    save_scores(scores)
                    scored_this_session += 1
                    style = "green" if score >= 7 else "yellow" if score >= 4 else "red"
                    console.print(f"  [{style}]{name} = {score}[/{style}]")
                    break
                else:
                    console.print("  [red]Score must be 0-10.[/red]")
            except ValueError:
                console.print("  [red]Enter a number 0-10, press enter to skip, or q to quit.[/red]")

    console.print(f"\n[green]Muster complete. Scored: {scored_this_session}, "
                  f"Skipped: {skipped_this_session}[/green]")
    render_summary(scores)


if __name__ == "__main__":
    main()
