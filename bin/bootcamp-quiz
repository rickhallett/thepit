#!/usr/bin/env bash
#
# bootcamp-quiz: ScriptEase wrapper for the Agentic Engineering Bootcamp
#
# Shows tips and quizzes filtered to the categories relevant to a specific
# bootcamp step. Designed to be called from shell initialization.
#
# Usage:
#   bootcamp-quiz STEP [--tip|--quiz|--info]
#
# Arguments:
#   STEP    Bootcamp step number (1-12)
#   --tip   Force show a tip (skip quiz chance)
#   --quiz  Force show a quiz
#   --info  Show which categories and tip IDs map to this step
#
# Examples:
#   bootcamp-quiz 2              # random tip/quiz for Step 2 (Shell Language)
#   bootcamp-quiz 4 --quiz       # quiz from Step 4 (Text Pipeline)
#   bootcamp-quiz 1 --info       # show Step 1 category mapping
#
# Environment:
#   SCRIPTEASE_HOME   Path to scriptease installation (default: ~/code/scriptease)
#   BOOTCAMP_STEP     Fallback step if no argument given

set -euo pipefail

SCRIPTEASE_HOME="${SCRIPTEASE_HOME:-$HOME/code/scriptease}"
SCRIPTEASE_BIN="${SCRIPTEASE_HOME}/bin/scriptease"

# Step-to-categories mapping
# Each step maps to one or more scriptease categories, comma-separated.
# The first category listed is the primary one for that step.
declare -A STEP_CATEGORIES=(
  [1]="process-management,pipes-redirection"
  [2]="bash-basics"
  [3]="file-operations"
  [4]="text-processing"
  [5]="python-oneliners"
  [6]="bash-basics"
  [7]="git-fu"
  [8]="process-management,networking"
  [9]="process-management,system-admin"
  [10]="networking"
  [11]="system-admin"
  [12]="bash-basics,pipes-redirection"
)

# Step names for display
declare -A STEP_NAMES=(
  [1]="Process Model (fork/exec/fd/pipe/signal)"
  [2]="Shell Language (POSIX/bash)"
  [3]="Filesystem as State"
  [4]="Text Pipeline (grep/sed/awk/jq)"
  [5]="Python CLI Tools"
  [6]="Make/Just Orchestration"
  [7]="Git Internals"
  [8]="Process Observation (strace/lsof/ss)"
  [9]="Container Internals"
  [10]="Networking CLI"
  [11]="Process Supervision"
  [12]="Advanced Bash"
)

# Tier assignments
declare -A STEP_TIERS=(
  [1]="Tier 1 (Foundational)"
  [2]="Tier 1 (Foundational)"
  [3]="Tier 1 (Foundational)"
  [4]="Tier 2 (Composition)"
  [5]="Tier 2 (Composition)"
  [6]="Tier 2 (Composition)"
  [7]="Tier 3 (Verification)"
  [8]="Tier 3 (Verification)"
  [9]="Tier 3 (Verification)"
  [10]="Tier 4 (Advanced)"
  [11]="Tier 4 (Advanced)"
  [12]="Tier 4 (Advanced)"
)

# Key tip IDs per step (subset most relevant to the step's specific focus)
declare -A STEP_KEY_TIPS=(
  [1]="301,302,303,309,317,501,503,504,505,506,515,519"
  [2]="101,102,103,104,105,106,107,108,109,110,111,112,113,114,115,116,117,118,119"
  [3]="401,402,403,404,405,406,416,418,419,420,421,424"
  [4]="201,202,203,204,205,206,207,208,209,210,211,212,213,214,215,219"
  [5]="701,702,703,704,705,706,707,708,709,710,711,712,713,714,715"
  [6]="108,112,113,115"
  [7]="901,902,903,904,905,906,907,908,909,910,911,912,913,914,915,916,917,918,919,920,921,922,923,924"
  [8]="310,311,312,313,316,319,602"
  [9]="314,315,811"
  [10]="601,602,603,604,605,606,607,608,609,610,611,612,613,614,615,616,617,618,619,620,621,622,623,624"
  [11]="801,802,803,804,805,824,827"
  [12]="114,116,118,119,502,508,509,510,513,516,517,519"
)

die() {
  printf "Error: %s\n" "$1" >&2
  exit 1
}

usage() {
  sed -n '2,/^$/s/^# //p' "$0" | sed '/^$/q'
}

show_info() {
  local step="$1"
  local name="${STEP_NAMES[$step]}"
  local tier="${STEP_TIERS[$step]}"
  local cats="${STEP_CATEGORIES[$step]}"
  local tips="${STEP_KEY_TIPS[$step]}"
  local tip_count
  tip_count=$(printf '%s' "$tips" | tr ',' '\n' | wc -l)

  printf "Step %s: %s\n" "$step" "$name"
  printf "Tier:       %s\n" "$tier"
  printf "Categories: %s\n" "$cats"
  printf "Key tips:   %s (%d tips)\n" "$tips" "$tip_count"

  # Show coverage gaps
  case "$step" in
    6) printf "\nNote: No Make/Just category in scriptease. Tips 108,112,113,115\n"
       printf "cover shell concepts used in Makefile recipes.\n" ;;
    9) printf "\nNote: Limited container coverage. Tips 314 (cgroups) and 315 (namespaces)\n"
       printf "cover kernel primitives. Docker/podman CLI not covered.\n" ;;
  esac
}

pick_category() {
  # Given a comma-separated list of categories, pick one at random
  local cats="$1"
  local -a arr
  IFS=',' read -ra arr <<< "$cats"
  local count=${#arr[@]}
  local idx=$((RANDOM % count))
  printf '%s' "${arr[$idx]}"
}

main() {
  local step=""
  local mode=""  # empty = default (scriptease decides tip vs quiz)

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tip)  mode="--tip"; shift ;;
      --quiz) mode="--quiz"; shift ;;
      --info) mode="info"; shift ;;
      -h|--help) usage; exit 0 ;;
      [0-9]|[0-9][0-9])
        step="$1"; shift ;;
      *)
        die "Unknown argument: $1. Usage: bootcamp-quiz STEP [--tip|--quiz|--info]" ;;
    esac
  done

  # Fall back to BOOTCAMP_STEP env var if no step argument
  if [[ -z "$step" ]]; then
    step="${BOOTCAMP_STEP:-}"
  fi

  if [[ -z "$step" ]]; then
    die "No step specified. Usage: bootcamp-quiz STEP [--tip|--quiz|--info]"
  fi

  # Validate step number
  if [[ "$step" -lt 1 || "$step" -gt 12 ]]; then
    die "Step must be between 1 and 12. Got: $step"
  fi

  # Handle --info mode
  if [[ "$mode" == "info" ]]; then
    show_info "$step"
    exit 0
  fi

  # Verify scriptease is available
  if [[ ! -x "$SCRIPTEASE_BIN" ]]; then
    die "scriptease not found at $SCRIPTEASE_BIN. Set SCRIPTEASE_HOME to your installation."
  fi

  # Pick a category from the step's category list
  local cats="${STEP_CATEGORIES[$step]}"
  local chosen_cat
  chosen_cat=$(pick_category "$cats")

  # Build scriptease command
  local -a cmd=("$SCRIPTEASE_BIN" "-c" "$chosen_cat")
  if [[ -n "$mode" ]]; then
    cmd+=("$mode")
  fi

  # Execute
  "${cmd[@]}"
}

main "$@"
