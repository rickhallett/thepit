#!/usr/bin/env python3
"""bosuns-scales - weigh the context.

The bosun inspects the rigging. These scales weigh the words
that agents load into context. Split into two categories:

  Auto-loaded: harness-injected, guaranteed present.
    AGENTS.md + the invoking agent's .claude/agents/{role}.md

  Instructed: standing orders say "read on load" but compliance
    depends on the agent following the instruction. Not injected
    by the harness. Would need @-prefix or explicit tool call.

Updates the '## Context Weight' section in AGENTS.md.

Usage: uv run bin/bosuns-scales
"""

import pathlib
import re
import sys

REPO_ROOT = pathlib.Path(__file__).resolve().parent.parent

# Auto-loaded by the harness on every invocation.
# AGENTS.md is always injected. The agent file is per-invocation
# (one of the .claude/agents/*.md files), so we report the range.
AUTO_LOADED = [
    "AGENTS.md",
]
AGENT_FILES_GLOB = ".claude/agents/*.md"

# Instructed reading: standing orders or depth-1 refs in AGENTS.md
# tell agents to read these, but the harness does not inject them.
INSTRUCTED = [
    ("docs/internal/slopodar.yaml", "mandatory reading [SD-286]"),
    ("docs/internal/lexicon.md", "read on load [SO-PERM-002]"),
    ("docs/internal/layer-model.md", "depth-1 reference"),
    ("docs/internal/session-decisions-index.yaml", "depth-1 orientation"),
]

AGENTS_MD = REPO_ROOT / "AGENTS.md"
SECTION_HEADER = "## Context Weight"


def count_words(filepath: pathlib.Path) -> int:
    """Count words in a file."""
    return len(filepath.read_text().split())


def build_weight_section() -> str:
    """Build the multi-line weight summary."""
    auto_parts = []
    auto_total = 0
    instructed_parts = []
    instructed_total = 0

    # Auto-loaded files
    for relpath in AUTO_LOADED:
        fp = REPO_ROOT / relpath
        if fp.exists():
            wc = count_words(fp)
            auto_total += wc
            auto_parts.append(f"{fp.name}: {wc:,}")

    # Agent files (auto-loaded, one per invocation)
    agent_files = sorted(REPO_ROOT.glob(AGENT_FILES_GLOB))
    if agent_files:
        agent_counts = [(f.name, count_words(f)) for f in agent_files]
        agent_total = sum(c for _, c in agent_counts)
        agent_min = min(c for _, c in agent_counts)
        agent_max = max(c for _, c in agent_counts)
        auto_total += agent_total
        auto_parts.append(
            f"agent files ({len(agent_counts)}): "
            f"{agent_total:,} (range {agent_min:,}-{agent_max:,})"
        )

    # Instructed files
    for relpath, _reason in INSTRUCTED:
        fp = REPO_ROOT / relpath
        if fp.exists():
            wc = count_words(fp)
            instructed_total += wc
            instructed_parts.append(f"{fp.name}: {wc:,}")

    grand_total = auto_total + instructed_total

    lines = [
        f"**Auto-loaded** (harness-injected, guaranteed): "
        f"**{auto_total:,}** - " + " | ".join(auto_parts),
        f"**Instructed** (standing orders, compliance varies): "
        f"**{instructed_total:,}** - " + " | ".join(instructed_parts),
        f"**Ceiling** (if everything gets read): **{grand_total:,}**",
    ]
    return "\n".join(lines)


def update_agents_md(section_body: str) -> bool:
    """Update or insert the Context Weight section in AGENTS.md."""
    content = AGENTS_MD.read_text()

    # Match the section: header, blank line, content until next section or ---
    section_pattern = re.compile(
        rf"({re.escape(SECTION_HEADER)}\n\n).*?(\n\n---)",
        re.DOTALL,
    )

    if section_pattern.search(content):
        new_content = section_pattern.sub(
            rf"\g<1>{section_body}\2",
            content,
        )
    else:
        # Insert before Provenance
        insert_before = "## Provenance"
        if insert_before in content:
            new_content = content.replace(
                insert_before,
                f"{SECTION_HEADER}\n\n{section_body}\n\n---\n\n{insert_before}",
            )
        else:
            new_content = content + f"\n\n{SECTION_HEADER}\n\n{section_body}\n"

    if new_content != content:
        AGENTS_MD.write_text(new_content)
        return True
    return False


def main() -> int:
    section_body = build_weight_section()
    print("Context weight:")
    print(section_body)
    print()

    changed = update_agents_md(section_body)
    if changed:
        print("AGENTS.md updated.")
    else:
        print("AGENTS.md unchanged (weights identical).")
    return 0


if __name__ == "__main__":
    sys.exit(main())
