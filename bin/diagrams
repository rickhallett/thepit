#!/bin/bash
# Midgets architecture diagrams - terminal display
# Usage: bin/diagrams [section]
#   bin/diagrams           show all
#   bin/diagrams stack     container stack only
#   bin/diagrams gate      gate pipeline only
#   bin/diagrams crew      crew workflow only
#   bin/diagrams gauntlet  gauntlet pipeline only

BOLD="\033[1m"
DIM="\033[2m"
CYAN="\033[36m"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
MAGENTA="\033[35m"
WHITE="\033[37m"
RESET="\033[0m"

show_stack() {
    printf "\n"
    printf "${BOLD}${CYAN}  MIDGET CONTAINER STACK${RESET}\n"
    printf "${DIM}  What lives inside every midget container${RESET}\n"
    printf "\n"
    printf "  +------------------------------------------------------------+\n"
    printf "  |  ${BOLD}debian:bookworm-slim${RESET}                                     |\n"
    printf "  |                                                            |\n"
    printf "  |  +------------------+  +-----------------------------+    |\n"
    printf "  |  | ${CYAN}Xvfb${RESET} :99         |  | ${CYAN}fluxbox${RESET}  (window manager)  |    |\n"
    printf "  |  | 1280x720x24      |  |                             |    |\n"
    printf "  |  +------------------+  +-----------------------------+    |\n"
    printf "  |                                                            |\n"
    printf "  |  +------------------+  +-----------------------------+    |\n"
    printf "  |  | ${GREEN}steer${RESET} CLI        |  | ${GREEN}drive${RESET} CLI                  |    |\n"
    printf "  |  | see, click, type |  | tmux + sentinel protocol    |    |\n"
    printf "  |  | hotkey, scroll   |  | run, send, poll, logs       |    |\n"
    printf "  |  | apps, clipboard  |  |                             |    |\n"
    printf "  |  +------------------+  +-----------------------------+    |\n"
    printf "  |                                                            |\n"
    printf "  |  +------------------+  +-----------------------------+    |\n"
    printf "  |  | ${GREEN}jobrunner${RESET}        |  | ${YELLOW}tesseract${RESET} OCR              |    |\n"
    printf "  |  | YAML in/out      |  | screen -> text              |    |\n"
    printf "  |  | atomic acquire   |  +-----------------------------+    |\n"
    printf "  |  +------------------+                                     |\n"
    printf "  |                                                            |\n"
    printf "  |  +------------------------------------------------------+ |\n"
    printf "  |  | ${MAGENTA}Agent CLIs${RESET}                                           | |\n"
    printf "  |  | claude  codex  gemini  pi  opencode                  | |\n"
    printf "  |  +------------------------------------------------------+ |\n"
    printf "  |                                                            |\n"
    printf "  |  +------------------+  +-----------------------------+    |\n"
    printf "  |  | ${YELLOW}Chrome${RESET}           |  | ${YELLOW}xterm${RESET} + DejaVu Sans Mono   |    |\n"
    printf "  |  | --no-sandbox     |  | xdotool, scrot, xclip       |    |\n"
    printf "  |  +------------------+  +-----------------------------+    |\n"
    printf "  |                                                            |\n"
    printf "  |  user: ${DIM}agent (uid 1000)${RESET}    entrypoint: ${DIM}entrypoint.sh${RESET}     |\n"
    printf "  +------------------------------------------------------------+\n"
    printf "\n"
}

show_gate() {
    printf "\n"
    printf "${BOLD}${GREEN}  QUALITY GATE${RESET}  ${DIM}make gate${RESET}\n"
    printf "${DIM}  35 tests across 6 suites, all inside the container${RESET}\n"
    printf "\n"
    printf "  docker build\n"
    printf "       |\n"
    printf "       v\n"
    printf "  +------------------+\n"
    printf "  | ${GREEN}test-poc.sh${RESET}       |  11 tests  steer: see, click, type, hotkey,\n"
    printf "  |                  |            apps, clipboard, screens, OCR verify\n"
    printf "  +------------------+\n"
    printf "       |\n"
    printf "  +------------------+\n"
    printf "  | ${GREEN}test-drive.sh${RESET}     |   9 tests  drive: session lifecycle, sentinel\n"
    printf "  |                  |            protocol, run/send/poll/logs\n"
    printf "  +------------------+\n"
    printf "       |\n"
    printf "  +------------------+\n"
    printf "  | ${GREEN}test-ocr.sh${RESET}       |   3 tests  tesseract installed, ocr_text field,\n"
    printf "  |                  |            live screen text extraction\n"
    printf "  +------------------+\n"
    printf "       |\n"
    printf "  +------------------+\n"
    printf "  | ${GREEN}test-chromium.sh${RESET}   |   3 tests  Chrome installed, window detected,\n"
    printf "  |                  |            OCR reads page content\n"
    printf "  +------------------+\n"
    printf "       |\n"
    printf "  +------------------+\n"
    printf "  | ${GREEN}test-agent.sh${RESET}     |   4 tests  node/claude present,\n"
    printf "  |                  |            observe->act->verify loop\n"
    printf "  +------------------+\n"
    printf "       |\n"
    printf "  +------------------+\n"
    printf "  | ${GREEN}test-jobs.sh${RESET}      |   5 tests  jobrunner: status, shell_command,\n"
    printf "  |                  |            output capture, fail verdict, once mode\n"
    printf "  +------------------+\n"
    printf "       |\n"
    printf "       v\n"
    printf "  ${GREEN}${BOLD}EXIT 0${RESET}  = gate green\n"
    printf "\n"
}

show_crew() {
    printf "\n"
    printf "${BOLD}${RED}  GOVERNANCE CREW${RESET}  ${DIM}make crew${RESET}\n"
    printf "${DIM}  The thesis proof: infrastructure-enforced role constraints${RESET}\n"
    printf "\n"
    printf "                      +------------------+\n"
    printf "                      | ${BOLD}Orchestrator${RESET}     |\n"
    printf "                      | ${DIM}(host)${RESET}           |\n"
    printf "                      +--------+---------+\n"
    printf "                               |\n"
    printf "              stages repo + diff with defect\n"
    printf "                               |\n"
    printf "          +--------------------+--------------------+\n"
    printf "          |                    |                    |\n"
    printf "          v                    v                    v\n"
    printf "  +---------------+   +---------------+   +---------------+\n"
    printf "  | ${YELLOW}Watchdog${RESET}      |   | ${CYAN}Weaver${RESET}        |   | ${RED}Sentinel${RESET}      |\n"
    printf "  |               |   |               |   |               |\n"
    printf "  | writes tests  |   | reviews diff  |   | scans for     |\n"
    printf "  | runs them     |   | quality +     |   | security      |\n"
    printf "  | reports       |   | correctness   |   | vulnerabilities|\n"
    printf "  |               |   |               |   |               |\n"
    printf "  | ${DIM}/opt/repo${RESET} ${RED}:ro${RESET} |   | ${DIM}/opt/repo${RESET} ${RED}:ro${RESET} |   | ${DIM}/opt/repo${RESET} ${RED}:ro${RESET} |\n"
    printf "  | ${DIM}/opt/jobs${RESET} ${GREEN}:rw${RESET} |   | ${DIM}/opt/jobs${RESET} ${GREEN}:rw${RESET} |   | ${DIM}/opt/jobs${RESET} ${GREEN}:rw${RESET} |\n"
    printf "  +-------+-------+   +-------+-------+   +-------+-------+\n"
    printf "          |                    |                    |\n"
    printf "          |   YAML review      |   YAML review     |   YAML review\n"
    printf "          |                    |                    |\n"
    printf "          +--------------------+--------------------+\n"
    printf "                               |\n"
    printf "                               v\n"
    printf "                      +------------------+\n"
    printf "                      | ${BOLD}Triangulation${RESET}    |\n"
    printf "                      |                  |\n"
    printf "                      | converge = high  |\n"
    printf "                      | confidence       |\n"
    printf "                      |                  |\n"
    printf "                      | diverge = human  |\n"
    printf "                      | escalation       |\n"
    printf "                      +--------+---------+\n"
    printf "                               |\n"
    printf "                               v\n"
    printf "                        ${BOLD}PASS / FAIL${RESET}\n"
    printf "\n"
    printf "  ${DIM}Key insight:${RESET} ${RED}:ro${RESET} = read-only mount (docker flag, not prompt)\n"
    printf "  ${DIM}An agent cannot modify source regardless of what it reasons.${RESET}\n"
    printf "\n"
}

show_gauntlet() {
    printf "\n"
    printf "${BOLD}${MAGENTA}  FULL GAUNTLET${RESET}  ${DIM}make gauntlet TIER=full${RESET}\n"
    printf "${DIM}  6-stage verification pipeline${RESET}\n"
    printf "\n"
    printf "  +============+     +============+     +============+\n"
    printf "  | ${GREEN}1. Gate${RESET}    |---->| ${GREEN}2. Interop${RESET} |---->| ${GREEN}3. Swarm${RESET}   |\n"
    printf "  | 35 tests   |     | 2 containers|     | N workers  |\n"
    printf "  | in-container|     | shared vol  |     | compose    |\n"
    printf "  +============+     +============+     +============+\n"
    printf "                                              |\n"
    printf "       +--------------------------------------+\n"
    printf "       |\n"
    printf "  +============+     +============+     +============+\n"
    printf "  | ${YELLOW}4. Crew${RESET}    |---->| ${RED}5. Darkcat${RESET} |---->| ${MAGENTA}6. Pitkeel${RESET} |\n"
    printf "  | mount flags |     | 3-model    |     | signal     |\n"
    printf "  | ro/rw proof |     | adversarial|     | analysis   |\n"
    printf "  +============+     +============+     +============+\n"
    printf "                                              |\n"
    printf "                                              v\n"
    printf "                                     ${GREEN}${BOLD}GAUNTLET COMPLETE${RESET}\n"
    printf "\n"
    printf "  ${DIM}Each stage writes an attestation. Any failure = pipeline stops.${RESET}\n"
    printf "\n"
}

show_interop() {
    printf "\n"
    printf "${BOLD}${WHITE}  INTER-CONTAINER COMMUNICATION${RESET}  ${DIM}make interop / make swarm${RESET}\n"
    printf "${DIM}  How midgets exchange work${RESET}\n"
    printf "\n"
    printf "                 +-----------------------------------+\n"
    printf "                 |    Docker Named Volume            |\n"
    printf "                 |    /opt/jobs/                     |\n"
    printf "                 |                                   |\n"
    printf "                 |  incoming/   done/   artifacts/   |\n"
    printf "                 +-----+-------------+-------+------+\n"
    printf "                       |             |       |\n"
    printf "           +-----------+    +--------+       +----------+\n"
    printf "           |                |                           |\n"
    printf "    +------+------+  +------+------+  +--------+-------+\n"
    printf "    | ${CYAN}Midget A${RESET}     |  | ${CYAN}Midget B${RESET}     |  | ${CYAN}Midget C${RESET}       |\n"
    printf "    |             |  |             |  |                |\n"
    printf "    | jobrunner   |  | jobrunner   |  | jobrunner     |\n"
    printf "    | --once      |  | --once      |  | --once        |\n"
    printf "    |             |  |             |  |                |\n"
    printf "    | reads job   |  | reads job   |  | reads job     |\n"
    printf "    | from        |  | from        |  | from          |\n"
    printf "    | incoming/   |  | incoming/   |  | incoming/     |\n"
    printf "    |             |  |             |  |                |\n"
    printf "    | writes      |  | writes      |  | writes        |\n"
    printf "    | result to   |  | result to   |  | result to     |\n"
    printf "    | done/       |  | done/       |  | done/         |\n"
    printf "    +-------------+  +-------------+  +---------------+\n"
    printf "\n"
    printf "  ${DIM}Job acquisition: atomic rename (.yaml -> .processing)${RESET}\n"
    printf "  ${DIM}No contention: if two workers race, exactly one wins.${RESET}\n"
    printf "\n"
}

show_all() {
    show_stack
    show_gate
    show_interop
    show_crew
    show_gauntlet
}

case "${1:-all}" in
    stack)    show_stack ;;
    gate)     show_gate ;;
    interop)  show_interop ;;
    crew)     show_crew ;;
    gauntlet) show_gauntlet ;;
    all)      show_all ;;
    *)        printf "Usage: bin/diagrams [stack|gate|interop|crew|gauntlet|all]\n" ;;
esac
