#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""Generate 27 adversarial review dispatch files (9 prompts x 3 models).

Each dispatch file is a self-contained prompt ready to paste into the target model.
Output: data/alley/bootcamp-adversarial/{model}/prompt-{N}-{name}.md
"""

import os
import re

MODELS = ["codex", "grok", "gemini"]
BASE = "data/alley/bootcamp-adversarial"

# Read the review instructions
with open(os.path.join(BASE, "review-instructions.md")) as f:
    instructions = f.read()

# Read the adversarial prompts
with open("docs/bootcamp/adversarial-review-prompts.md") as f:
    raw = f.read()

# Parse individual prompts by splitting on ## Prompt N:
prompt_blocks = re.split(r'\n## Prompt (\d+):', raw)
# First element is the preamble, then alternating number/content
prompts = {}
for i in range(1, len(prompt_blocks), 2):
    num = int(prompt_blocks[i])
    content = prompt_blocks[i + 1].strip()
    # Extract short name from first line
    first_line = content.split('\n')[0].strip()
    prompts[num] = {
        "name": re.sub(r'[^a-z0-9]+', '-', first_line.lower()).strip('-')[:30],
        "content": content
    }

PROMPT_NAMES = {
    1: "repackaging",
    2: "depth-test",
    3: "accuracy-audit",
    4: "irreplaceability",
    5: "audience-problem",
    6: "completeness-trap",
    7: "slop-detector",
    8: "pedagogy-review",
    9: "so-what-test",
}

# Files the model should read (paths relative to repo root)
FILE_ACCESS = {
    1: ["sites/oceanheart/content/blog/2026-03-10-agentic-bootcamp.md",
        "sites/oceanheart/content/bootcamp/01-process-model.md",
        "sites/oceanheart/content/bootcamp/07-git-internals.md",
        "sites/oceanheart/content/bootcamp/12-advanced-bash.md"],
    2: ["sites/oceanheart/content/bootcamp/01-process-model.md"],
    3: ["sites/oceanheart/content/bootcamp/02-shell-language.md",
        "sites/oceanheart/content/bootcamp/04-text-pipeline.md"],
    4: ["sites/oceanheart/content/blog/2026-03-10-agentic-bootcamp.md",
        "sites/oceanheart/content/bootcamp/01-process-model.md",
        "sites/oceanheart/content/bootcamp/09-container-internals.md"],
    5: ["sites/oceanheart/content/blog/2026-03-10-agentic-bootcamp.md",
        "sites/oceanheart/content/bootcamp/_index.md"],
    6: ["sites/oceanheart/content/blog/2026-03-10-agentic-bootcamp.md",
        "sites/oceanheart/content/bootcamp/_index.md"],
    7: ["sites/oceanheart/content/blog/2026-03-10-agentic-bootcamp.md",
        "sites/oceanheart/content/bootcamp/01-process-model.md",
        "sites/oceanheart/content/bootcamp/03-filesystem-as-state.md",
        "docs/internal/slopodar.yaml"],
    8: ["sites/oceanheart/content/bootcamp/01-process-model.md",
        "sites/oceanheart/content/bootcamp/05-python-cli-tools.md"],
    9: ["sites/oceanheart/content/blog/2026-03-10-agentic-bootcamp.md",
        "sites/oceanheart/content/bootcamp/01-process-model.md"],
}

count = 0
for model in MODELS:
    model_dir = os.path.join(BASE, model)
    os.makedirs(model_dir, exist_ok=True)

    for num in range(1, 10):
        name = PROMPT_NAMES[num]
        prompt_content = prompts[num]["content"]
        files = FILE_ACCESS[num]

        # Read the actual file contents to embed
        file_contents = []
        for fpath in files:
            if os.path.exists(fpath):
                with open(fpath) as f:
                    file_contents.append(f"### File: `{fpath}`\n\n```\n{f.read()}\n```")
            else:
                file_contents.append(f"### File: `{fpath}` (NOT FOUND)")

        dispatch = f"""# Adversarial Review Dispatch
# Model: {model} | Prompt: {num} | Name: {name}
# Run: bootcamp-adversarial-2026-03-10

---

{instructions}

---

## Your Specific Assignment

{prompt_content}

---

## Source Material

Read the following files carefully before responding. These are the complete contents.

{"".join(chr(10) + c + chr(10) for c in file_contents)}

---

## Output Requirements

1. Write your narrative assessment (Section 1)
2. End with the structured YAML findings block (Section 2)
3. Use `prompt_id: {num}` and `prompt_name: "{name}"` in your YAML header
4. Use `model: "{model}"` in your YAML header
5. Classify each finding with an attack vector from the taxonomy
6. Be honest. If the criticism does not hold up, say so.
"""

        outpath = os.path.join(model_dir, f"prompt-{num}-{name}.md")
        with open(outpath, "w") as f:
            f.write(dispatch)
        count += 1

print(f"Generated {count} dispatch files across {len(MODELS)} models")
for model in MODELS:
    model_dir = os.path.join(BASE, model)
    files = sorted(os.listdir(model_dir))
    print(f"  {model}/: {len(files)} files")
    for f in files:
        size = os.path.getsize(os.path.join(model_dir, f))
        print(f"    {f} ({size:,} bytes)")
