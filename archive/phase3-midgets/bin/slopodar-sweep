#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml>=6.0", "anthropic>=0.42", "openai>=1.58", "google-genai>=1.0"]
# ///
"""
slopodar-sweep - Cross-model adversarial slopodar pattern detection across git history.

Extracts prose corpus from multiple repos, chunks by document boundaries,
sends each chunk to multiple LLM models with the slopodar taxonomy,
collects structured YAML findings, and aggregates results.

Usage:
    slopodar-sweep extract [--repos <paths>] [--out <dir>]
    slopodar-sweep sweep [--corpus <dir>] [--models <list>] [--out <dir>] [--chunk <id>]
    slopodar-sweep aggregate [--data <dir>] [--out <dir>]

Subcommands:
    extract    - Walk repos, extract prose, chunk into files
    sweep      - Send chunks to models, collect findings
    aggregate  - Parse all responses, cross-reference, produce convergence data

Backrefs: SD-318 (Darkcat Alley), slopodar.yaml, archaeology-excavation-2026-03-11.md
"""

from __future__ import annotations

import json
import os
import re
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

import yaml


# -- Constants ---------------------------------------------------------------

REPO_ROOT = Path(__file__).resolve().parent.parent
SLOPODAR_PATH = REPO_ROOT / "docs" / "internal" / "slopodar.yaml"
ENV_PATH = REPO_ROOT / ".env"

DEFAULT_REPOS = [
    str(REPO_ROOT),                         # midgets/phantoms
    str(REPO_ROOT.parent / "noopit"),       # noopit
    str(REPO_ROOT.parent / "jobsworth"),    # jobsworth
]

# Directories to skip during extraction (duplicates, generated, deps)
SKIP_DIRS = {
    "node_modules", ".git", "build", ".next", ".vercel", "dist",
    "coverage", ".turbo", "__pycache__", ".pytest_cache",
    "data/alley",       # already-reviewed alley data
    ".worktrees",       # git worktree duplicates
    ".venv", "venv",    # virtualenvs
    "python-docs",      # jobsworth python docs (reference material, not our prose)
    "interview-prep",   # jobsworth interview prep challenges (third-party content)
    "ebook", "ebook-slim",  # build artifacts of bootcamp
}

# Files to skip (too large, generated, or not prose)
SKIP_FILES = {
    "pnpm-lock.yaml", "uv.lock", "package-lock.json",
    "CHANGELOG.md",  # generated changelogs
}

# Max file size to extract (skip anything over 100k chars / ~25k tokens)
MAX_FILE_CHARS = 100_000

# Only extract these extensions
PROSE_EXTENSIONS = {".md", ".yaml", ".yml"}

# Rough token estimate: 1 token ~= 4 chars
CHARS_PER_TOKEN = 4
TARGET_CHUNK_TOKENS = 40_000
TARGET_CHUNK_CHARS = TARGET_CHUNK_TOKENS * CHARS_PER_TOKEN

# Model configs - defaults overridden by .env (ANTHROPIC_MODEL, OPENAI_MODEL, etc.)
MODELS = {
    "claude": {
        "api": "anthropic",
        "model": "claude-haiku-4-5-20251001",
        "env_key": "ANTHROPIC_API_KEY",
        "model_env_key": "ANTHROPIC_MODEL",
    },
    "gpt": {
        "api": "openai",
        "model": "gpt-5-mini-2025-08-07",
        "env_key": "OPENAI_API_KEY",
        "model_env_key": "OPENAI_MODEL",
    },
    "gemini": {
        "api": "google",
        "model": "gemini-3-flash-preview",
        "env_key": "GEMINI_API_KEY",
        "model_env_key": "GEMINI_MODEL",
    },
    "grok": {
        "api": "xai",
        "model": "grok-4-1-fast-reasoning",
        "env_key": "XAI_API_KEY",
        "model_env_key": "GROK_MODEL",
    },
}


def _resolve_models(env: dict[str, str]) -> None:
    """Override hardcoded model identifiers from .env if present."""
    for key, config in MODELS.items():
        env_model = env.get(config.get("model_env_key", ""))
        if env_model:
            config["model"] = env_model


# -- Env loading -------------------------------------------------------------

def load_env(env_path: Path) -> dict[str, str]:
    """Load key=value pairs from a .env file."""
    env = {}
    if not env_path.exists():
        return env
    for line in env_path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            k, v = line.split("=", 1)
            env[k.strip()] = v.strip()
    return env


# -- Corpus extraction -------------------------------------------------------

def should_skip_path(path: Path, repo_root: Path) -> bool:
    """Check if a path should be skipped during extraction."""
    rel = str(path.relative_to(repo_root))
    parts = path.parts

    # Skip directories
    for skip_dir in SKIP_DIRS:
        if skip_dir in parts or rel.startswith(skip_dir):
            return True

    # Skip files
    if path.name in SKIP_FILES:
        return True

    return False


def extract_file(path: Path, repo_root: Path, repo_name: str) -> dict | None:
    """Extract a single prose file with metadata."""
    # Skip files that are too large (reference material, not our prose)
    try:
        size = path.stat().st_size
        if size > MAX_FILE_CHARS:
            return None
    except OSError:
        return None

    try:
        content = path.read_text(encoding="utf-8", errors="replace")
    except (OSError, UnicodeDecodeError):
        return None

    if not content.strip():
        return None

    rel_path = str(path.relative_to(repo_root))
    lines = content.count("\n") + 1

    return {
        "repo": repo_name,
        "path": rel_path,
        "lines": lines,
        "chars": len(content),
        "content": content,
    }


def extract_commit_messages(repo_path: Path, repo_name: str) -> dict | None:
    """Extract all commit messages from a repo as a single document."""
    try:
        result = subprocess.run(
            ["git", "log", "--format=%H|%ai|%s", "--all"],
            capture_output=True, text=True, cwd=repo_path, timeout=30,
        )
        if result.returncode != 0:
            return None
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None

    lines = result.stdout.strip().splitlines()
    if not lines:
        return None

    # Format as readable document
    content_lines = [f"# Commit Messages - {repo_name}", f"# {len(lines)} commits", ""]
    for line in lines:
        parts = line.split("|", 2)
        if len(parts) == 3:
            sha, date, msg = parts
            content_lines.append(f"[{sha[:8]}] {date[:10]} {msg}")

    content = "\n".join(content_lines)
    return {
        "repo": repo_name,
        "path": "_commit_messages.txt",
        "lines": len(content_lines),
        "chars": len(content),
        "content": content,
    }


def extract_corpus(repo_paths: list[str]) -> list[dict]:
    """Extract all prose documents from repos."""
    docs = []
    seen_content_hashes: set[int] = set()

    for repo_path_str in repo_paths:
        repo_path = Path(repo_path_str).resolve()
        if not repo_path.exists():
            print(f"  SKIP: {repo_path} does not exist", file=sys.stderr)
            continue

        repo_name = repo_path.name
        print(f"  Extracting from {repo_name}...", file=sys.stderr)

        # Walk for prose files
        count = 0
        for ext in PROSE_EXTENSIONS:
            for path in repo_path.rglob(f"*{ext}"):
                if should_skip_path(path, repo_path):
                    continue

                doc = extract_file(path, repo_path, repo_name)
                if doc is None:
                    continue

                # Deduplicate by content hash
                content_hash = hash(doc["content"])
                if content_hash in seen_content_hashes:
                    continue
                seen_content_hashes.add(content_hash)

                docs.append(doc)
                count += 1

        # Extract commit messages
        commit_doc = extract_commit_messages(repo_path, repo_name)
        if commit_doc:
            docs.append(commit_doc)
            count += 1

        print(f"    {count} documents extracted", file=sys.stderr)

    return docs


def chunk_documents(docs: list[dict]) -> list[dict]:
    """Group documents into chunks respecting token budget.

    Each chunk is a dict with:
        - id: chunk-NNN
        - documents: list of doc dicts
        - total_chars: total characters in chunk
        - total_tokens_est: estimated token count
    """
    # Sort by size descending - large docs get their own chunk
    docs_sorted = sorted(docs, key=lambda d: d["chars"], reverse=True)

    chunks = []
    current_chunk_docs = []
    current_chars = 0
    chunk_id = 0

    for doc in docs_sorted:
        doc_chars = doc["chars"]

        # If single doc exceeds budget, it gets its own chunk
        if doc_chars > TARGET_CHUNK_CHARS:
            if current_chunk_docs:
                chunk_id += 1
                chunks.append({
                    "id": f"chunk-{chunk_id:03d}",
                    "documents": current_chunk_docs,
                    "total_chars": current_chars,
                    "total_tokens_est": current_chars // CHARS_PER_TOKEN,
                })
                current_chunk_docs = []
                current_chars = 0

            chunk_id += 1
            chunks.append({
                "id": f"chunk-{chunk_id:03d}",
                "documents": [doc],
                "total_chars": doc_chars,
                "total_tokens_est": doc_chars // CHARS_PER_TOKEN,
            })
            continue

        # If adding this doc would exceed budget, close current chunk
        if current_chars + doc_chars > TARGET_CHUNK_CHARS and current_chunk_docs:
            chunk_id += 1
            chunks.append({
                "id": f"chunk-{chunk_id:03d}",
                "documents": current_chunk_docs,
                "total_chars": current_chars,
                "total_tokens_est": current_chars // CHARS_PER_TOKEN,
            })
            current_chunk_docs = []
            current_chars = 0

        current_chunk_docs.append(doc)
        current_chars += doc_chars

    # Final chunk
    if current_chunk_docs:
        chunk_id += 1
        chunks.append({
            "id": f"chunk-{chunk_id:03d}",
            "documents": current_chunk_docs,
            "total_chars": current_chars,
            "total_tokens_est": current_chars // CHARS_PER_TOKEN,
        })

    return chunks


def write_chunks(chunks: list[dict], out_dir: Path) -> None:
    """Write chunks to disk as individual files."""
    out_dir.mkdir(parents=True, exist_ok=True)

    manifest = []
    for chunk in chunks:
        chunk_file = out_dir / f"{chunk['id']}.md"
        lines = [
            f"# Corpus Chunk: {chunk['id']}",
            f"# Documents: {len(chunk['documents'])}",
            f"# Estimated tokens: {chunk['total_tokens_est']}",
            "",
        ]
        for doc in chunk["documents"]:
            lines.append(f"---")
            lines.append(f"## [{doc['repo']}] {doc['path']} ({doc['lines']} lines)")
            lines.append("")
            lines.append(doc["content"])
            lines.append("")

        chunk_file.write_text("\n".join(lines), encoding="utf-8")

        manifest.append({
            "id": chunk["id"],
            "file": str(chunk_file.relative_to(out_dir.parent.parent)),
            "documents": len(chunk["documents"]),
            "chars": chunk["total_chars"],
            "tokens_est": chunk["total_tokens_est"],
            "doc_list": [
                {"repo": d["repo"], "path": d["path"], "lines": d["lines"]}
                for d in chunk["documents"]
            ],
        })

    # Write manifest
    manifest_file = out_dir / "manifest.yaml"
    with open(manifest_file, "w") as f:
        yaml.dump(manifest, f, default_flow_style=False, sort_keys=False, allow_unicode=True)

    print(f"\n  Wrote {len(chunks)} chunks to {out_dir}/", file=sys.stderr)
    print(f"  Manifest: {manifest_file}", file=sys.stderr)


# -- Prompt construction ----------------------------------------------------

def build_prompt(slopodar_content: str, chunk_content: str, chunk_id: str) -> str:
    """Build the adversarial slopodar sweep prompt for a chunk."""
    return f"""You are performing an adversarial anti-pattern audit of prose and configuration artifacts from an AI-assisted engineering project. Your job is to find instances of known anti-patterns AND propose new pattern categories.

This project has been built over 400+ commits across 3 repos by a human operator working with LLM agents (primarily Claude). The artifacts include: session decisions, agent identity files, cover letters, configuration, documentation, and commit messages.

You are not the author. You have no loyalty to this content. Your job is to find what is wrong, not to praise what is right.

## THE SLOPODAR TAXONOMY

Below is the full taxonomy of anti-patterns already identified in this project. Your task is to:
(a) Find NEW INSTANCES of these patterns in the corpus chunk below
(b) Propose NEW CATEGORIES not yet in the taxonomy, but ONLY if you find 3+ examples

{slopodar_content}

## INSTRUCTIONS

### Task A: Instance Detection

For each instance found:
- Map to an existing slopodar pattern name
- Cite verbatim text (exact quote, max 200 chars)
- Note the file path and approximate location
- Rate confidence: high (clear match), medium (probable), low (possible)

### Task B: New Category Proposals

For each proposed new category:
- Name it (lowercase-hyphenated, like existing patterns)
- Define it in one sentence
- Describe the mechanism (why does this happen?)
- Provide 3+ examples with verbatim quotes from the chunk
- Explain why it is distinct from existing patterns

### What NOT to do

- Do not praise the content. Every line of praise displaces a finding.
- Do not flag things that are intentional and acknowledged (e.g., the slopodar itself discusses these patterns - finding them IN the slopodar taxonomy definition is not a catch).
- Do not propose categories with fewer than 3 examples.
- Do not confuse technical terminology with slop. Domain-specific language is not nominalisation.
- Do not flag markdown formatting as a pattern.

## REQUIRED OUTPUT FORMAT

Your response MUST end with a fenced YAML block containing structured findings. This block will be machine-parsed.

```yaml
review:
  model: "<your model name>"
  date: "{datetime.now(timezone.utc).strftime('%Y-%m-%d')}"
  chunk: "{chunk_id}"
  documents_reviewed: <number of documents in this chunk>

instance_findings:
  - id: I-001
    pattern: "<existing slopodar pattern name>"
    file: "<repo/path>"
    quote: "<verbatim text, max 200 chars>"
    confidence: high  # high | medium | low
    explanation: "<why this matches the pattern>"

  # ... one entry per instance found

new_categories:
  - id: C-001
    name: "<proposed-pattern-name>"
    definition: "<one sentence definition>"
    mechanism: "<why this happens>"
    distinct_from: "<existing pattern it might be confused with>"
    examples:
      - file: "<repo/path>"
        quote: "<verbatim text>"
      - file: "<repo/path>"
        quote: "<verbatim text>"
      - file: "<repo/path>"
        quote: "<verbatim text>"

  # ... one entry per proposed category (only if 3+ examples)

summary:
  instances_found: <total count>
  new_categories_proposed: <total count>
  highest_density_pattern: "<pattern name with most instances>"
  highest_density_file: "<file with most instances>"
```

## CORPUS CHUNK TO REVIEW

{chunk_content}
"""


# -- API callers -------------------------------------------------------------

def call_anthropic(prompt: str, api_key: str, model: str) -> str:
    """Call Anthropic API."""
    from anthropic import Anthropic

    client = Anthropic(api_key=api_key)
    response = client.messages.create(
        model=model,
        max_tokens=8192,
        messages=[{"role": "user", "content": prompt}],
    )
    return response.content[0].text


def call_openai(prompt: str, api_key: str, model: str) -> str:
    """Call OpenAI API."""
    from openai import OpenAI

    client = OpenAI(api_key=api_key)
    response = client.chat.completions.create(
        model=model,
        max_completion_tokens=16384,
        messages=[{"role": "user", "content": prompt}],
    )
    content = response.choices[0].message.content
    if not content:
        # Check for refusal or other issues
        finish = response.choices[0].finish_reason
        print(f"    OpenAI finish_reason: {finish}", file=sys.stderr)
        if hasattr(response.choices[0].message, 'refusal') and response.choices[0].message.refusal:
            print(f"    OpenAI refusal: {response.choices[0].message.refusal}", file=sys.stderr)
        print(f"    OpenAI usage: {response.usage}", file=sys.stderr)
        return ""
    return content


def call_xai(prompt: str, api_key: str, model: str) -> str:
    """Call xAI (Grok) API via OpenAI-compatible endpoint."""
    from openai import OpenAI

    client = OpenAI(api_key=api_key, base_url="https://api.x.ai/v1")
    response = client.chat.completions.create(
        model=model,
        max_completion_tokens=8192,
        messages=[{"role": "user", "content": prompt}],
    )
    return response.choices[0].message.content


def call_google(prompt: str, api_key: str, model: str) -> str:
    """Call Google Gemini API."""
    from google import genai

    client = genai.Client(api_key=api_key)
    response = client.models.generate_content(
        model=model,
        contents=prompt,
        config={
            "max_output_tokens": 8192,
        },
    )
    return response.text


API_CALLERS = {
    "anthropic": call_anthropic,
    "openai": call_openai,
    "xai": call_xai,
    "google": call_google,
}


def call_model(model_key: str, prompt: str, env: dict[str, str]) -> str | None:
    """Call a model by key. Returns response text or None on failure."""
    config = MODELS[model_key]
    api_key = env.get(config["env_key"])
    if not api_key:
        print(f"  SKIP {model_key}: no {config['env_key']} found", file=sys.stderr)
        return None

    caller = API_CALLERS[config["api"]]
    try:
        print(f"  Calling {model_key} ({config['model']})...", file=sys.stderr)
        start = time.time()
        result = caller(prompt, api_key, config["model"])
        elapsed = time.time() - start
        print(f"    Done in {elapsed:.1f}s ({len(result)} chars)", file=sys.stderr)
        return result
    except Exception as e:
        print(f"  ERROR {model_key}: {e}", file=sys.stderr)
        return None


# -- YAML extraction from responses -----------------------------------------

def fix_yaml_quoting(yaml_text: str) -> str:
    """Fix common YAML quoting issues from LLM output.

    LLMs often produce YAML like:
        explanation: "Beyond X is Y" pattern where Y implies not-X
    which breaks because the first " pair is treated as a quoted scalar.

    Fix: for any value line that has unmatched or embedded quotes,
    wrap the entire value in a block scalar.
    """
    fixed_lines = []
    for line in yaml_text.splitlines():
        stripped = line.strip()
        # Skip empty lines, pure comments, list-only markers
        if not stripped or stripped.startswith("#"):
            fixed_lines.append(line)
            continue

        # Find key: value lines (not list items that start with -)
        # Match: optional indent, optional "- ", key: value
        m = re.match(r'^(\s*(?:-\s+)?)(\w[\w-]*)\s*:\s*(.+)$', line)
        if m:
            prefix, key, val = m.group(1), m.group(2), m.group(3)
            # Count unescaped double quotes
            quote_count = val.count('"') - val.count('\\"')
            # If odd number of quotes, or starts with quote but has content after closing quote
            if quote_count % 2 != 0 or (val.startswith('"') and not val.endswith('"')):
                # Escape any single quotes in val, wrap in single quotes
                escaped = val.replace("'", "''")
                fixed_lines.append(f"{prefix}{key}: '{escaped}'")
                continue
            # If value starts with " and has internal quotes that confuse YAML
            if val.startswith('"') and val.count('"') > 2:
                escaped = val.replace("'", "''")
                fixed_lines.append(f"{prefix}{key}: '{escaped}'")
                continue

        fixed_lines.append(line)
    return "\n".join(fixed_lines)


def _has_findings(parsed: dict) -> bool:
    """Check if parsed YAML contains findings in any format."""
    return any(k in parsed for k in ("instance_findings", "new_categories", "findings"))


def _normalize_findings(parsed: dict) -> dict:
    """Normalize findings format: convert darkcat 'findings' to 'instance_findings'."""
    if "findings" in parsed and "instance_findings" not in parsed:
        # Convert darkcat format findings to instance_findings
        findings = parsed.pop("findings")
        instance_findings = []
        for f in (findings or []):
            if isinstance(f, dict):
                instance_findings.append({
                    "id": f.get("id", "?"),
                    "pattern": f.get("slopodar", f.get("watchdog", "unknown")),
                    "file": f.get("file", "?"),
                    "quote": f.get("description", "")[:200],
                    "confidence": "high" if f.get("severity") in ("critical", "high") else "medium",
                    "explanation": f.get("description", ""),
                })
        parsed["instance_findings"] = instance_findings
    if "new_categories" not in parsed:
        parsed["new_categories"] = []
    return parsed


def extract_yaml_from_response(text: str) -> dict | None:
    """Extract the structured YAML block from a model response.

    Handles common issues:
    - Missing closing fence (Gemini often omits it)
    - YAML parse errors from unescaped quotes
    """
    # Try with closing fence first
    pattern = r"```ya?ml\s*\n(.*?)```"
    matches = re.findall(pattern, text, re.DOTALL)

    # If no match with closing fence, try without (greedy to end)
    if not matches:
        pattern_open = r"```ya?ml\s*\n(.*)"
        matches = re.findall(pattern_open, text, re.DOTALL)

    for match in matches:
        # First try direct parse
        try:
            parsed = yaml.safe_load(match)
            if isinstance(parsed, dict) and _has_findings(parsed):
                return _normalize_findings(parsed)
        except yaml.YAMLError:
            pass

        # Try with quote fixing
        fixed = fix_yaml_quoting(match)
        try:
            parsed = yaml.safe_load(fixed)
            if isinstance(parsed, dict) and _has_findings(parsed):
                return _normalize_findings(parsed)
        except yaml.YAMLError:
            pass

    return None


# -- Aggregation -------------------------------------------------------------

def aggregate_results(data_dir: Path) -> dict:
    """Aggregate all model responses across all chunks."""
    all_instances = []   # (model, chunk, finding)
    all_categories = []  # (model, chunk, category)
    chunk_stats = []

    # Walk response files
    for response_file in sorted(data_dir.rglob("*.yaml")):
        if response_file.name == "manifest.yaml" or response_file.name == "aggregate.yaml":
            continue

        try:
            with open(response_file) as f:
                data = yaml.safe_load(f)
        except (yaml.YAMLError, OSError):
            continue

        if not isinstance(data, dict):
            continue

        # Extract model key and chunk from filename (chunk-NNN_modelkey.yaml)
        # This is authoritative - models self-report inconsistently (35+ names for 3 models)
        stem = response_file.stem  # e.g. "chunk-042_grok"
        parts = stem.rsplit("_", 1)
        model = parts[1] if len(parts) == 2 else data.get("review", {}).get("model", "unknown")
        chunk = parts[0] if len(parts) == 2 else data.get("review", {}).get("chunk", "unknown")

        for inst in data.get("instance_findings", []) or []:
            if isinstance(inst, dict):
                inst["_model"] = model
                inst["_chunk"] = chunk
                # Normalise pattern name: lowercase, strip quotes
                p = inst.get("pattern", "unknown")
                if isinstance(p, str):
                    inst["pattern"] = p.lower().strip().strip('"').strip("'").replace(" ", "-")
                all_instances.append(inst)

        for cat in data.get("new_categories", []) or []:
            if isinstance(cat, dict):
                cat["_model"] = model
                cat["_chunk"] = chunk
                # Normalise category name
                n = cat.get("name", "unknown")
                if isinstance(n, str):
                    cat["name"] = n.lower().strip().strip('"').strip("'").replace(" ", "-")
                all_categories.append(cat)

        summary = data.get("summary", {})
        chunk_stats.append({
            "chunk": chunk,
            "model": model,
            "instances_found": summary.get("instances_found", len(data.get("instance_findings", []) or [])),
            "new_categories_proposed": summary.get("new_categories_proposed", len(data.get("new_categories", []) or [])),
            "highest_density_pattern": summary.get("highest_density_pattern"),
            "highest_density_file": summary.get("highest_density_file"),
        })

    # Instance pattern frequency across models
    pattern_counts: dict[str, dict[str, int]] = {}
    for inst in all_instances:
        pattern = inst.get("pattern", "unknown")
        model = inst.get("_model", "unknown")
        if pattern not in pattern_counts:
            pattern_counts[pattern] = {}
        pattern_counts[pattern][model] = pattern_counts[pattern].get(model, 0) + 1

    # New category convergence - same name proposed by multiple models
    category_proposals: dict[str, list[str]] = {}
    category_details: dict[str, list[dict]] = {}
    for cat in all_categories:
        name = cat.get("name", "unknown")
        model = cat.get("_model", "unknown")
        if name not in category_proposals:
            category_proposals[name] = []
            category_details[name] = []
        if model not in category_proposals[name]:
            category_proposals[name].append(model)
        category_details[name].append(cat)

    # Build aggregate report
    aggregate = {
        "computed_at": datetime.now(timezone.utc).isoformat(),
        "totals": {
            "total_instances": len(all_instances),
            "total_new_categories": len(all_categories),
            "unique_patterns_flagged": len(pattern_counts),
            "unique_new_categories": len(category_proposals),
        },
        "pattern_frequency": {
            pattern: {
                "total": sum(models.values()),
                "by_model": models,
                "model_count": len(models),
            }
            for pattern, models in sorted(
                pattern_counts.items(),
                key=lambda x: sum(x[1].values()),
                reverse=True,
            )
        },
        "new_category_convergence": {
            name: {
                "proposed_by": models,
                "model_count": len(models),
                "confidence": "high" if len(models) >= 3 else "medium" if len(models) >= 2 else "low",
            }
            for name, models in sorted(
                category_proposals.items(),
                key=lambda x: len(x[1]),
                reverse=True,
            )
        },
        "new_category_details": {
            name: details
            for name, details in category_details.items()
        },
        "chunk_stats": chunk_stats,
        "all_instances": all_instances,
    }

    return aggregate


def format_aggregate_summary(agg: dict) -> str:
    """Format human-readable summary of aggregate results."""
    lines = []
    lines.append("=" * 72)
    lines.append("  SLOPODAR SWEEP - AGGREGATE RESULTS")
    lines.append("=" * 72)
    lines.append("")

    t = agg["totals"]
    lines.append(f"Total instances found:     {t['total_instances']}")
    lines.append(f"Unique patterns flagged:   {t['unique_patterns_flagged']}")
    lines.append(f"New categories proposed:   {t['total_new_categories']}")
    lines.append(f"Unique new categories:     {t['unique_new_categories']}")
    lines.append("")

    lines.append("PATTERN FREQUENCY (instances across all models):")
    for pattern, data in agg["pattern_frequency"].items():
        model_str = ", ".join(f"{m}:{c}" for m, c in data["by_model"].items())
        convergence = f"[{data['model_count']} models]" if data["model_count"] > 1 else "[1 model]"
        lines.append(f"  {pattern:40s} {data['total']:3d} instances  {convergence}  ({model_str})")
    lines.append("")

    lines.append("NEW CATEGORY CONVERGENCE:")
    for name, data in agg["new_category_convergence"].items():
        models_str = ", ".join(data["proposed_by"])
        lines.append(f"  {name:40s} {data['confidence']:6s}  proposed by: {models_str}")
    lines.append("")

    # High-confidence new categories (2+ models)
    high_conf = {n: d for n, d in agg["new_category_convergence"].items() if d["model_count"] >= 2}
    if high_conf:
        lines.append("HIGH-CONFIDENCE NEW CATEGORIES (2+ models independently):")
        for name, data in high_conf.items():
            lines.append(f"  {name}")
            # Pull definition from details
            details = agg.get("new_category_details", {}).get(name, [])
            for d in details:
                if d.get("definition"):
                    lines.append(f"    [{d.get('_model', '?')}] {d['definition']}")
        lines.append("")

    lines.append("=" * 72)
    lines.append(f"  Computed: {agg['computed_at']}")
    lines.append("=" * 72)

    return "\n".join(lines)


# -- CLI commands ------------------------------------------------------------

def cmd_extract(args: list[str]) -> None:
    """Extract corpus from repos and chunk into files."""
    repos = DEFAULT_REPOS
    out_dir = REPO_ROOT / "data" / "sweep" / "corpus"

    # Parse args
    i = 0
    while i < len(args):
        if args[i] == "--repos" and i + 1 < len(args):
            repos = args[i + 1].split(",")
            i += 2
        elif args[i] == "--out" and i + 1 < len(args):
            out_dir = Path(args[i + 1])
            i += 2
        else:
            i += 1

    print("Extracting corpus...", file=sys.stderr)
    docs = extract_corpus(repos)
    print(f"\nTotal documents: {len(docs)}", file=sys.stderr)
    total_chars = sum(d["chars"] for d in docs)
    print(f"Total chars: {total_chars:,} (~{total_chars // CHARS_PER_TOKEN:,} tokens)", file=sys.stderr)

    print("\nChunking...", file=sys.stderr)
    chunks = chunk_documents(docs)
    print(f"Chunks: {len(chunks)}", file=sys.stderr)
    for chunk in chunks:
        n_docs = len(chunk["documents"])
        print(f"  {chunk['id']}: {n_docs} docs, ~{chunk['total_tokens_est']:,} tokens", file=sys.stderr)

    write_chunks(chunks, out_dir)


def _sweep_one(
    chunk_id: str,
    model_key: str,
    prompt: str,
    env: dict[str, str],
    out_dir: Path,
    semaphores: dict[str, Any],
) -> dict:
    """Process a single (chunk, model) pair. Thread-safe.

    Returns a status dict for reporting.
    """
    response_file = out_dir / f"{chunk_id}_{model_key}.md"
    yaml_file = out_dir / f"{chunk_id}_{model_key}.yaml"

    # Skip if already done
    if yaml_file.exists():
        return {"chunk": chunk_id, "model": model_key, "status": "skipped"}

    # Acquire per-provider semaphore to limit concurrency per API
    provider = MODELS[model_key]["api"]
    sem = semaphores.get(provider)

    if sem:
        sem.acquire()
    try:
        response = call_model(model_key, prompt, env)
    finally:
        if sem:
            sem.release()

    if response is None:
        return {"chunk": chunk_id, "model": model_key, "status": "error", "instances": 0, "categories": 0}

    # Save raw response
    response_file.write_text(response, encoding="utf-8")

    # Extract and save structured YAML
    parsed = extract_yaml_from_response(response)
    if parsed:
        with open(yaml_file, "w") as f:
            yaml.dump(parsed, f, default_flow_style=False, sort_keys=False, allow_unicode=True, width=120)
        inst_count = len(parsed.get("instance_findings", []) or [])
        cat_count = len(parsed.get("new_categories", []) or [])
        print(f"  OK {chunk_id}/{model_key}: {inst_count} instances, {cat_count} new categories", file=sys.stderr)
        return {"chunk": chunk_id, "model": model_key, "status": "ok", "instances": inst_count, "categories": cat_count}
    else:
        print(f"  WARN {chunk_id}/{model_key}: YAML parse failed", file=sys.stderr)
        yaml_file.write_text(f"# PARSE FAILED - raw response in {response_file.name}\n", encoding="utf-8")
        return {"chunk": chunk_id, "model": model_key, "status": "parse_failed", "instances": 0, "categories": 0}


def cmd_sweep(args: list[str]) -> None:
    """Send chunks to models and collect findings. Parallelised."""
    from concurrent.futures import ThreadPoolExecutor, as_completed
    from threading import Semaphore

    corpus_dir = REPO_ROOT / "data" / "sweep" / "corpus"
    out_dir = REPO_ROOT / "data" / "sweep" / "responses"
    model_keys = list(MODELS.keys())
    chunk_filter = None
    max_workers = 12

    # Parse args
    i = 0
    while i < len(args):
        if args[i] == "--corpus" and i + 1 < len(args):
            corpus_dir = Path(args[i + 1])
            i += 2
        elif args[i] == "--out" and i + 1 < len(args):
            out_dir = Path(args[i + 1])
            i += 2
        elif args[i] == "--models" and i + 1 < len(args):
            model_keys = args[i + 1].split(",")
            i += 2
        elif args[i] == "--chunk" and i + 1 < len(args):
            chunk_filter = args[i + 1]
            i += 2
        elif args[i] == "--workers" and i + 1 < len(args):
            max_workers = int(args[i + 1])
            i += 2
        else:
            i += 1

    # Load env and resolve model identifiers
    env = load_env(ENV_PATH)
    for key in ["ANTHROPIC_API_KEY", "OPENAI_API_KEY", "GEMINI_API_KEY", "XAI_API_KEY"]:
        if key not in env and key in os.environ:
            env[key] = os.environ[key]
    _resolve_models(env)

    # Load slopodar
    if not SLOPODAR_PATH.exists():
        print(f"ERROR: slopodar not found at {SLOPODAR_PATH}", file=sys.stderr)
        sys.exit(1)
    slopodar_content = SLOPODAR_PATH.read_text(encoding="utf-8")

    # Find chunk files
    chunk_files = sorted(corpus_dir.glob("chunk-*.md"))
    if chunk_filter:
        chunk_files = [f for f in chunk_files if chunk_filter in f.stem]

    if not chunk_files:
        print(f"ERROR: no chunk files found in {corpus_dir}", file=sys.stderr)
        sys.exit(1)

    total_jobs = len(chunk_files) * len(model_keys)
    print(f"Sweep: {len(chunk_files)} chunks x {len(model_keys)} models = {total_jobs} jobs, {max_workers} workers", file=sys.stderr)
    out_dir.mkdir(parents=True, exist_ok=True)

    # Per-provider semaphores: limit concurrent requests per API to avoid rate limits
    providers = set(MODELS[k]["api"] for k in model_keys)
    semaphores = {p: Semaphore(3) for p in providers}

    # Build all (chunk, model, prompt) jobs
    jobs = []
    for chunk_file in chunk_files:
        chunk_id = chunk_file.stem
        chunk_content = chunk_file.read_text(encoding="utf-8")
        prompt = build_prompt(slopodar_content, chunk_content, chunk_id)
        for model_key in model_keys:
            jobs.append((chunk_id, model_key, prompt))

    # Execute in parallel
    completed = 0
    ok = 0
    errors = 0
    skipped = 0
    total_instances = 0
    total_categories = 0
    start_time = time.time()

    with ThreadPoolExecutor(max_workers=max_workers) as pool:
        futures = {
            pool.submit(_sweep_one, chunk_id, model_key, prompt, env, out_dir, semaphores): (chunk_id, model_key)
            for chunk_id, model_key, prompt in jobs
        }

        for future in as_completed(futures):
            completed += 1
            try:
                result = future.result()
                status = result["status"]
                if status == "ok":
                    ok += 1
                    total_instances += result.get("instances", 0)
                    total_categories += result.get("categories", 0)
                elif status == "skipped":
                    skipped += 1
                else:
                    errors += 1
            except Exception as e:
                chunk_id, model_key = futures[future]
                print(f"  EXCEPTION {chunk_id}/{model_key}: {e}", file=sys.stderr)
                errors += 1

            # Progress
            elapsed = time.time() - start_time
            rate = completed / elapsed if elapsed > 0 else 0
            remaining = (total_jobs - completed) / rate if rate > 0 else 0
            print(
                f"  [{completed}/{total_jobs}] ok={ok} skip={skipped} err={errors} "
                f"inst={total_instances} cats={total_categories} "
                f"({elapsed:.0f}s elapsed, ~{remaining:.0f}s remaining)",
                file=sys.stderr,
            )

    elapsed = time.time() - start_time
    print(f"\nSweep complete: {ok} ok, {skipped} skipped, {errors} errors in {elapsed:.0f}s", file=sys.stderr)
    print(f"Total: {total_instances} instances, {total_categories} new categories", file=sys.stderr)


def cmd_aggregate(args: list[str]) -> None:
    """Aggregate all responses and produce convergence data."""
    data_dir = REPO_ROOT / "data" / "sweep" / "responses"
    out_dir = REPO_ROOT / "data" / "sweep"

    i = 0
    while i < len(args):
        if args[i] == "--data" and i + 1 < len(args):
            data_dir = Path(args[i + 1])
            i += 2
        elif args[i] == "--out" and i + 1 < len(args):
            out_dir = Path(args[i + 1])
            i += 2
        else:
            i += 1

    print("Aggregating results...", file=sys.stderr)
    agg = aggregate_results(data_dir)

    # Write aggregate YAML
    agg_file = out_dir / "aggregate.yaml"
    with open(agg_file, "w") as f:
        yaml.dump(agg, f, default_flow_style=False, sort_keys=False, allow_unicode=True, width=120)
    print(f"  Wrote {agg_file}", file=sys.stderr)

    # Print summary
    print()
    print(format_aggregate_summary(agg))


def usage() -> None:
    """Print usage."""
    print(__doc__)
    sys.exit(1)


def main() -> None:
    """CLI entrypoint."""
    args = sys.argv[1:]
    if not args:
        usage()

    cmd = args[0]
    rest = args[1:]

    commands = {
        "extract": cmd_extract,
        "sweep": cmd_sweep,
        "aggregate": cmd_aggregate,
    }

    if cmd in commands:
        commands[cmd](rest)
    elif cmd in ("-h", "--help", "help"):
        usage()
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        usage()


if __name__ == "__main__":
    main()
