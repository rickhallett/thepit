#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["pyyaml>=6.0"]
# ///
"""Prepare bootcamp content for EPUB generation.

Reads Hugo content files, strips TOML frontmatter, orders by part/step,
generates book structure (title page, preface, part dividers, appendices,
colophon), and outputs a pandoc manifest for EPUB conversion.

Editions:
  full - all 51 chapters, 456k words (~1,800 pages)
  slim - 26 chapters, ~248k words (~1,000 pages), cross-model reviewed

Usage:
  uv run bin/ebook-prep                    # full edition
  uv run bin/ebook-prep --edition slim     # slim edition
  uv run bin/ebook-prep --dry-run          # show what would be done
  uv run bin/ebook-prep --manifest-only    # print manifest to stdout

Source: sites/oceanheart/content/bootcamp/*.md
Output: build/ebook/{frontmatter,parts,chapters,appendices}/*.md + manifest.txt

Backrefs: AGENTS.md (conventions), docs/bootcamp/README.md (curriculum)
Slim provenance: data/ebook-review/ (9 cross-model assessments, 3 axes x 3 models)
"""
import argparse
import re
import sys
import uuid
from datetime import date
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
HUGO_DIR = REPO_ROOT / "sites" / "oceanheart" / "content" / "bootcamp"
BUILD_DIR = REPO_ROOT / "build" / "ebook"

# Slim edition inclusion set.
# Provenance: cross-model adversarial review (Claude, Codex/GPT-5.4, Gemini).
# 3 independent axes (availability, structural necessity, additive priority),
# 9 total assessments, triangulated. See data/ebook-review/aggregation.md.
#
# Inclusion criteria:
#   - Part II complete: all 3 models converged on this as the core
#   - SCARCE availability chapters: material hard to find elsewhere
#   - DAG-respecting: all dependencies included
#   - Budget target: ~250k words
SLIM_INCLUDE = {
  # Part I: substrate grounding (1 chapter)
  (1, 1),   # The Unix Process Model
  # Part II: complete (11 chapters) - the core, all 3 models agreed
  (2, 1),   # How LLMs Actually Work
  (2, 2),   # Agent Architecture Patterns
  (2, 3),   # Prompt Engineering as System Design
  (2, 4),   # Context Engineering [SCARCE]
  (2, 5),   # Tool Design and ACIs
  (2, 6),   # Verification and Quality [SCARCE]
  (2, 7),   # The Human-AI Interface [SCARCE]
  (2, 8),   # Multi-Model Verification
  (2, 9),   # Failure Modes and Recovery [SCARCE]
  (2, 10),  # Governance and Enterprise Integration
  (2, 11),  # Cost, Security, Legal
  # Part III: analytics that serve agent work specifically (4 chapters)
  (3, 1),   # Tabular Data - dep for III.7, III.8
  (3, 2),   # Descriptive Statistics - dep for III.8
  (3, 7),   # Log Analysis Patterns [PARTIALLY]
  (3, 8),   # Cost Modelling [PARTIALLY]
  # Part IV: eval and red teaming (7 chapters)
  (4, 1),   # What Evals Measure [SCARCE]
  (4, 2),   # Eval Datasets - dep for IV.3, IV.4
  (4, 3),   # Scoring and Grading - dep for IV.5, IV.6
  (4, 5),   # Eval Infrastructure
  (4, 6),   # Adversarial Testing [SCARCE]
  (4, 7),   # Red Teaming [SCARCE]
  (4, 8),   # Interpreting Results
  # Part V: SCARCE infrastructure (3 chapters)
  (5, 5),   # State Management [SCARCE]
  (5, 7),   # Observability and Tracing
  (5, 8),   # Debugging Agents [SCARCE]
}

# Edition configurations
EDITIONS = {
  'full': {
    'name': 'Full Edition',
    'version_suffix': '',
    'filter': None,  # include all
    'description': (
      "51 steps across 5 structured programmes covering Linux substrate, "
      "agentic engineering practices, operational analytics, evaluation "
      "and adversarial testing, and agent infrastructure in practice."
    ),
  },
  'slim': {
    'name': 'Slim Edition',
    'version_suffix': '-slim',
    'filter': SLIM_INCLUDE,
    'description': (
      "26 chapters selected by cross-model adversarial review. "
      "The material that is hardest to find elsewhere: context engineering, "
      "verification for probabilistic systems, the human-AI interface, "
      "evaluation methodology, adversarial testing, and agent debugging."
    ),
  },
}

# Part metadata: bootcamp number -> (title, file prefix pattern, step count)
PARTS = {
  1: {
    "title": "Linux Substrate",
    "prefix": re.compile(r'^\d{2}-'),
    "step_count": 12,
    "subtitle": "The kernel primitives, shell, filesystem, containers, and networking that agents actually run on.",
  },
  2: {
    "title": "Agentic Engineering Practices",
    "prefix": re.compile(r'^ii-\d{2}-'),
    "step_count": 11,
    "subtitle": "How to work with agents: architecture, context engineering, verification, the human-AI interface, governance.",
  },
  3: {
    "title": "Operational Analytics",
    "prefix": re.compile(r'^iii-\d{2}-'),
    "step_count": 10,
    "subtitle": "The 20% of data science that does 80% of the heavy lifting.",
  },
  4: {
    "title": "Evaluation and Adversarial Testing",
    "prefix": re.compile(r'^iv-\d{2}-'),
    "step_count": 9,
    "subtitle": "How do you know if it is working? Eval design, LLM-as-judge, agent evaluation, red teaming, safety.",
  },
  5: {
    "title": "Agent Infrastructure in Practice",
    "prefix": re.compile(r'^v-\d{2}-'),
    "step_count": 9,
    "subtitle": "RAG, state management, conversation memory, observability, debugging, production patterns.",
  },
}


def parse_toml_frontmatter(text: str) -> tuple[dict, str]:
  """Extract TOML frontmatter and return (metadata_dict, body).

  Parses the subset of TOML used in bootcamp files: simple key = value pairs.
  """
  match = re.match(r'\+\+\+\n(.*?)\n\+\+\+\n?(.*)', text, re.DOTALL)
  if not match:
    return {}, text

  toml_block = match.group(1)
  body = match.group(2)

  meta = {}
  for line in toml_block.split('\n'):
    line = line.strip()
    if not line or line.startswith('#'):
      continue
    kv = re.match(r'(\w+)\s*=\s*(.*)', line)
    if kv:
      key = kv.group(1)
      val = kv.group(2).strip()
      # Parse value types
      if val.startswith('"') and val.endswith('"'):
        meta[key] = val[1:-1]
      elif val.startswith('[') and val.endswith(']'):
        # Simple list of strings
        items = re.findall(r'"([^"]*)"', val)
        meta[key] = items
      elif val in ('true', 'false'):
        meta[key] = val == 'true'
      else:
        try:
          meta[key] = int(val)
        except ValueError:
          meta[key] = val

  return meta, body


def strip_step_subtitle(body: str) -> str:
  """Remove the 'Step N of M in Bootcamp X:...' line that hugo-convert-bootcamp adds."""
  lines = body.split('\n')
  cleaned = []
  for line in lines:
    if re.match(r'^Step \d+ of \d+ in Bootcamp', line.strip()):
      continue
    cleaned.append(line)
  return '\n'.join(cleaned)


def clean_body(body: str) -> str:
  """Clean body text for EPUB: strip Hugo artifacts, normalise whitespace."""
  body = strip_step_subtitle(body)
  # Strip leading/trailing whitespace but preserve internal structure
  body = body.strip()
  return body


def collect_chapters(include_filter=None) -> list[dict]:
  """Collect chapter files with metadata, sorted by part then step.

  Args:
    include_filter: if set, a set of (bootcamp, step) tuples to include.
                    Chapters not in the set are excluded.
  """
  chapters = []

  for path in sorted(HUGO_DIR.glob('*.md')):
    if path.name == '_index.md':
      continue

    meta, body = parse_toml_frontmatter(path.read_text())

    if 'bootcamp' not in meta or 'step' not in meta:
      sys.stderr.write(f"WARNING: {path.name} missing bootcamp/step metadata, skipping\n")
      continue

    # Apply edition filter
    if include_filter is not None:
      key = (meta['bootcamp'], meta['step'])
      if key not in include_filter:
        continue

    chapters.append({
      'path': path,
      'filename': path.name,
      'bootcamp': meta['bootcamp'],
      'step': meta['step'],
      'title': meta.get('title', path.stem),
      'tier': meta.get('tier', 0),
      'estimate': meta.get('estimate', ''),
      'body': clean_body(body),
    })

  # Sort by bootcamp number, then step number
  chapters.sort(key=lambda c: (c['bootcamp'], c['step']))
  return chapters


def generate_title_page(edition: dict) -> str:
  """Generate title page markdown."""
  edition_label = edition['name']
  return f"""---
title-meta: "The Agentic Engineer"
---

\\newpage

# The Agentic Engineer {{.unnumbered}}

## A Practitioner's Field Manual {{.unnumbered}}

**Version 1.0 - {edition_label}**

Richard Hallett

OCEANHEART.AI LTD

{date.today().strftime('%B %Y')}

---

*First principles for engineers who govern what agents build.*
"""


def generate_copyright() -> str:
  """Generate copyright page markdown."""
  year = date.today().year
  return f"""\\newpage

## Copyright {{.unnumbered}}

Copyright {year} OCEANHEART.AI LTD (UK company number 16029162).

All rights reserved.

---

This material was developed during a multi-month calibration run combining
operational engineering with systematic study of human-AI collaboration.
Approximately 82% of the content is grounded in established frameworks
(Lean/Toyota, SRE, CRM, Bainbridge 1983, Reason 1990, Denning 1968,
Avizienis 1985, Helmreich 1999). The remaining 18% - the context engineering
vocabulary, HCI foot guns, anti-pattern taxonomy, and operational layer
model - is genuinely novel, identified as such throughout, and declared
explicitly.

Built with pandoc. Source files in Markdown.
"""


PREFACE_FULL = """\\newpage

## Preface {.unnumbered}

This is not a tutorial collection. It is a first-principles curriculum where
each step composes into the next, ordered by the dependency graph of the
underlying systems.

Five structured programmes take a competent software engineer to a competent
agentic engineer - someone who can develop, verify, evaluate, and govern
agent-native systems.

**Part I: Linux Substrate** - the kernel primitives, shell, filesystem,
containers, and networking that agents actually run on. 12 steps.

**Part II: Agentic Engineering Practices** - how to work with agents:
architecture, context engineering, verification, the human-AI interface,
governance. 11 steps.

**Part III: Operational Analytics** - the 20% of data science that does 80%
of the heavy lifting. pandas, DuckDB, statistics, visualisation, cost
modelling. 10 steps.

**Part IV: Evaluation and Adversarial Testing** - how do you know if it is
working? Eval design, LLM-as-judge, agent evaluation, red teaming, safety.
9 steps.

**Part V: Agent Infrastructure in Practice** - RAG, state management,
conversation memory, observability, debugging, production patterns. 9 steps.

Total: 51 steps, approximately 208-259 hours. Not a weekend project - a
practitioner's field guide built from operational experience.

### Ranking Criteria

The learning order within each part follows three criteria:

1. **Compositional leverage** - does this knowledge compose into everything above it?
2. **Return per hour** - how much capability per unit of learning time?
3. **Irreplaceability** - can an agent compensate for your ignorance, or must you understand it?

The third criterion is the differentiator. In the operator model, you steer
and verify. Where ignorance creates oracle problems - errors that propagate
through every verification layer because no layer has authority above you -
that knowledge is irreplaceable and ranks highest.

### Conventions

- Challenges are marked with **Challenge:** headers
- Agentic context is marked with **> AGENTIC GROUNDING:** blockquotes
- Historical notes are marked with **> HISTORY:** blockquotes
- Field maturity is marked with **> FIELD MATURITY:** blockquotes
- Anti-patterns are marked with **> SLOPODAR:** blockquotes
- All code examples are runnable on Linux

---
"""

PREFACE_SLIM = """\\newpage

## Preface {.unnumbered}

This is the slim edition. The full curriculum contains 51 chapters across
456,000 words. This edition contains 26 chapters - the material that three
independent AI models, assessed across three separate axes, converged on as
hardest to find elsewhere and most structurally necessary.

What survived the cut: all of Part II (the agentic engineering core -
context engineering, verification, the human-AI interface, failure modes),
the evaluation and adversarial testing methodology from Part IV, and the
infrastructure chapters from Part V where published coverage is thinnest.

What was cut: the Linux substrate (widely covered by existing resources),
most of the operational analytics (pandas, DuckDB, statistics - well served
by existing textbooks), and the infrastructure chapters where tutorials
already exist at equivalent depth.

The full edition is recommended for readers building their first complete
mental model. This edition is for practitioners who already know Linux and
data analysis and want the material that does not exist anywhere else.

### How This Edition Was Selected

The inclusion set was determined by cross-model adversarial review: three
prompts (resource availability, structural necessity, additive priority)
run independently across three model families (Claude, GPT, Gemini) - nine
total assessments with no shared context between runs. Chapters that all
three models independently rated as having scarce equivalent-depth coverage
elsewhere were prioritised. The dependency graph was respected throughout.

### Conventions

- Challenges are marked with **Challenge:** headers
- Agentic context is marked with **> AGENTIC GROUNDING:** blockquotes
- Historical notes are marked with **> HISTORY:** blockquotes
- Field maturity is marked with **> FIELD MATURITY:** blockquotes
- Anti-patterns are marked with **> SLOPODAR:** blockquotes
- All code examples are runnable on Linux

---
"""


def generate_preface(edition_key: str) -> str:
  """Generate preface for the given edition."""
  if edition_key == 'slim':
    return PREFACE_SLIM
  return PREFACE_FULL


def generate_part_divider(part_num: int) -> str:
  """Generate a part divider page."""
  meta = PARTS[part_num]
  return f"""\\newpage

# Part {part_num_to_roman(part_num)}: {meta['title']} {{.unnumbered}}

*{meta['subtitle']}*

---
"""


def generate_colophon(edition: dict, chapter_count: int) -> str:
  """Generate colophon page."""
  today = date.today().strftime('%Y-%m-%d')
  edition_note = ""
  if edition['name'] == 'Slim Edition':
    edition_note = """
**Edition note:** This slim edition was selected by cross-model adversarial
review: 3 assessment axes (resource availability, structural necessity,
additive priority) x 3 model families (Claude, GPT, Gemini) = 9 independent
assessments. Chapters were prioritised by scarcity of equivalent-depth
coverage in existing published resources and structural necessity within
the curriculum dependency graph. The full edition contains 51 chapters.
"""

  return f"""\\newpage

## Colophon {{.unnumbered}}

**Title:** The Agentic Engineer: A Practitioner's Field Manual

**Version:** 1.0 - {edition['name']}

**Chapters:** {chapter_count}

**Build date:** {today}

**Author:** Richard Hallett

**Publisher:** OCEANHEART.AI LTD

**Provenance:** Derived from operational experience across 300+ session
decisions, a 13-layer operational model, 18+ named anti-patterns, 7 named
HCI foot guns, and a 50+ term lexicon developed during a multi-month
calibration run combining agentic engineering with systematic study of
human-AI collaboration.
{edition_note}
**Toolchain:** Markdown source, pandoc 3.5, EPUB3.

**Established frameworks cited:** Lean/Toyota (poka-yoke, kaizen, andon cord),
SRE (quality gates, incident response), CRM (readback, authority gradients),
Swiss Cheese Model (Reason 1990), N-version programming (Avizienis 1985),
Ironies of Automation (Bainbridge 1983), Working Set Model (Denning 1968),
Information Retrieval (Manning et al. 2008).
"""


def part_num_to_roman(n: int) -> str:
  """Convert part number to Roman numeral."""
  return {1: 'I', 2: 'II', 3: 'III', 4: 'IV', 5: 'V'}[n]


def write_file(path: Path, content: str, dry_run: bool = False) -> None:
  """Write content to file, creating parent dirs."""
  if dry_run:
    sys.stderr.write(f"  DRY RUN: would write {path} ({content.count(chr(10))} lines)\n")
    return
  path.parent.mkdir(parents=True, exist_ok=True)
  path.write_text(content)


def generate_metadata_yaml(edition: dict, edition_key: str) -> str:
  """Generate pandoc EPUB metadata YAML."""
  today = date.today().strftime('%Y-%m-%d')
  uuid_ns = f'https://oceanheart.ai/bootcamp/v1.0{edition["version_suffix"]}'
  book_uuid = str(uuid.uuid5(uuid.NAMESPACE_URL, uuid_ns))
  subtitle = f"A Practitioner's Field Manual - {edition['name']}"
  desc = edition['description']
  return f"""---
title: "The Agentic Engineer"
subtitle: "{subtitle}"
author: "Richard Hallett"
rights: "Copyright {date.today().year} OCEANHEART.AI LTD"
language: en-GB
publisher: "OCEANHEART.AI LTD"
date: "{today}"
description: >
  First principles for engineers who govern what agents build.
  {desc}
identifier:
  - scheme: UUID
    text: "urn:uuid:{book_uuid}"
---
"""


def build_ebook(edition_key: str = 'full', dry_run: bool = False) -> list[str]:
  """Build the ebook staging directory for the given edition. Returns manifest lines."""

  edition = EDITIONS[edition_key]
  include_filter = edition['filter']

  # Resolve build directory per edition
  build_dir = BUILD_DIR if edition_key == 'full' else REPO_ROOT / "build" / f"ebook-{edition_key}"

  chapters = collect_chapters(include_filter=include_filter)
  sys.stderr.write(f"[{edition['name']}] Collected {len(chapters)} chapters\n")

  # Count words
  total_words = sum(len(ch['body'].split()) for ch in chapters)
  sys.stderr.write(f"[{edition['name']}] Total words: {total_words:,}\n")

  # Validate: for full edition, check completeness
  if edition_key == 'full':
    for part_num, meta in PARTS.items():
      part_chapters = [c for c in chapters if c['bootcamp'] == part_num]
      if len(part_chapters) != meta['step_count']:
        sys.stderr.write(
          f"WARNING: Part {part_num} ({meta['title']}): "
          f"expected {meta['step_count']} chapters, found {len(part_chapters)}\n"
        )

  manifest = []

  # --- Metadata ---
  meta_path = build_dir / "metadata.yaml"
  write_file(meta_path, generate_metadata_yaml(edition, edition_key), dry_run)

  # --- Frontmatter ---
  fm_dir = build_dir / "frontmatter"

  title_path = fm_dir / "01-title.md"
  write_file(title_path, generate_title_page(edition), dry_run)
  manifest.append(str(title_path))

  copyright_path = fm_dir / "02-copyright.md"
  write_file(copyright_path, generate_copyright(), dry_run)
  manifest.append(str(copyright_path))

  preface_path = fm_dir / "03-preface.md"
  write_file(preface_path, generate_preface(edition_key), dry_run)
  manifest.append(str(preface_path))

  # --- Parts and Chapters ---
  current_part = None
  for ch in chapters:
    part_num = ch['bootcamp']

    # Emit part divider when part changes
    if part_num != current_part:
      current_part = part_num
      part_path = build_dir / "parts" / f"part-{part_num:02d}.md"
      write_file(part_path, generate_part_divider(part_num), dry_run)
      manifest.append(str(part_path))

    # Write chapter
    # Build chapter heading from metadata
    # Use H1 so pandoc splits each chapter into its own XHTML file
    roman = part_num_to_roman(part_num)
    chapter_heading = f"# {roman}.{ch['step']}: {ch['title']}"
    if ch['estimate']:
      chapter_heading += f"\n\n*Estimated time: {ch['estimate']}*"

    chapter_content = f"{chapter_heading}\n\n{ch['body']}\n"

    chapter_filename = f"{part_num:02d}-{ch['step']:02d}-{ch['filename']}"
    chapter_path = build_dir / "chapters" / chapter_filename
    write_file(chapter_path, chapter_content, dry_run)
    manifest.append(str(chapter_path))

  # --- Colophon ---
  colophon_path = build_dir / "backmatter" / "colophon.md"
  write_file(colophon_path, generate_colophon(edition, len(chapters)), dry_run)
  manifest.append(str(colophon_path))

  # --- Write manifest ---
  manifest_path = build_dir / "manifest.txt"
  manifest_content = '\n'.join(manifest) + '\n'
  write_file(manifest_path, manifest_content, dry_run)

  # Store build_dir for main() to reference
  build_ebook._last_build_dir = build_dir

  return manifest


def main():
  parser = argparse.ArgumentParser(
    description="Prepare bootcamp content for EPUB generation"
  )
  parser.add_argument('--edition', choices=list(EDITIONS.keys()), default='full',
                      help='Edition to build (default: full)')
  parser.add_argument('--dry-run', action='store_true',
                      help='Show what would be done without writing')
  parser.add_argument('--manifest-only', action='store_true',
                      help='Print manifest to stdout after building')
  args = parser.parse_args()

  edition = EDITIONS[args.edition]
  build_dir = BUILD_DIR if args.edition == 'full' else REPO_ROOT / "build" / f"ebook-{args.edition}"

  # Clean build directory (unless dry run)
  if not args.dry_run and build_dir.exists():
    import shutil
    shutil.rmtree(build_dir)
    build_dir.mkdir(parents=True)

  manifest = build_ebook(edition_key=args.edition, dry_run=args.dry_run)

  sys.stderr.write(f"\nManifest: {len(manifest)} files\n")

  if args.manifest_only:
    for line in manifest:
      print(line)

  if not args.dry_run:
    suffix = edition['version_suffix']
    epub_name = f"the-agentic-engineer-v1.0{suffix}.epub"
    sys.stderr.write(f"Output: {build_dir}/\n")
    sys.stderr.write(f"Metadata: {build_dir}/metadata.yaml\n")
    sys.stderr.write(f"Manifest: {build_dir}/manifest.txt\n")
    sys.stderr.write(f"\nNext: pandoc --from markdown --to epub3 "
                     f"--metadata-file {build_dir}/metadata.yaml "
                     f"--toc --toc-depth 2 "
                     f"--split-level 1 "
                     f"--css assets/ebook.css "
                     f"-o {build_dir}/{epub_name} "
                     f"$(cat {build_dir}/manifest.txt)\n")


if __name__ == '__main__':
  main()
