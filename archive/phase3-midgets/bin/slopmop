#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["anthropic>=0.40", "python-dotenv"]
# ///
"""
slopmop - Scan markdown for AI slop and muster findings for keyboard-first decisioning.

Phase 1: Regex scan for slop candidates (blockquotes, em-dashes, epigrammatic patterns).
Phase 2: LLM pass (claude-haiku-4-5) classifies each candidate.
Phase 3: Interactive keyboard muster - one keypress per finding.

Usage:
    slopmop scan [path]              # scan only, print candidates (no LLM)
    slopmop review [path]            # scan + LLM classify + interactive muster
    slopmop report [path]            # scan + LLM classify + print report (non-interactive)

Options:
    --include-historical             # include files in archive/historical dirs (default: skip)
    --pattern blockquote,emdash,epigram  # comma-separated pattern types (default: all)
    --out <file>                     # write decisions to TSV file

Backrefs: SD-319 (no em-dash/emoji), slopodar.yaml (anti-pattern taxonomy)
Provenance: slop-audit-2026-03-10.md (first manual audit that motivated this tool)
"""

import argparse
import json
import os
import re
import sys
import termios
import tty
from dataclasses import dataclass, field
from pathlib import Path
from datetime import datetime, timezone
from typing import Optional

from dotenv import load_dotenv

load_dotenv()

# ---------------------------------------------------------------------------
# Data model
# ---------------------------------------------------------------------------

@dataclass
class SlopCandidate:
    file: str
    line: int
    line_end: int
    pattern_type: str          # blockquote | emdash | epigram | emoji
    text: str                  # the raw text found
    context: str               # surrounding lines for display
    verdict: str = ""          # KILL | TRIM | KEEP | SKIP (set by LLM or human)
    reason: str = ""           # LLM's reasoning
    confidence: float = 0.0    # LLM's confidence 0-1


# ---------------------------------------------------------------------------
# Phase 1: Regex scanning
# ---------------------------------------------------------------------------

SKIP_DIRS = {
    ".git", "node_modules", ".next", ".cache", "__pycache__",
    "data/signal-test",  # historical test data
}

ARCHIVE_DIRS = {
    "archive", "archive-v1-lullaby", "ice",
}

EM_DASH = "\u2014"


def should_skip(path: Path, include_historical: bool) -> bool:
    parts = set(path.parts)
    if parts & SKIP_DIRS:
        return True
    if not include_historical and parts & ARCHIVE_DIRS:
        return True
    return False


def scan_blockquotes(filepath: Path, lines: list[str]) -> list[SlopCandidate]:
    """Find > blockquotes, especially file-header epigrams."""
    candidates = []
    i = 0
    while i < len(lines):
        line = lines[i]
        if not line.startswith("> "):
            i += 1
            continue

        # Collect contiguous blockquote
        block_start = i
        block_lines = []
        while i < len(lines) and (lines[i].startswith("> ") or lines[i].strip() == ">"):
            block_lines.append(lines[i])
            i += 1

        text = "\n".join(block_lines)

        # Skip blockquotes that are clearly metadata (contain dates, status, epic, etc.)
        metadata_signals = ["**Status:**", "**Date:**", "**Epic:**", "**Decided by:**",
                           "**Governs:**", "Created:", "Updated:", "Covers:", "SHA",
                           "Source:", "Operator verification", "v1", "v2", "Archived"]
        if any(sig in text for sig in metadata_signals):
            continue

        # Skip blockquotes that are mission statements (functional)
        if text.startswith("> **Mission:**"):
            continue

        # Get context (2 lines before, 2 after)
        ctx_start = max(0, block_start - 2)
        ctx_end = min(len(lines), i + 2)
        context = "\n".join(lines[ctx_start:ctx_end])

        candidates.append(SlopCandidate(
            file=str(filepath),
            line=block_start + 1,  # 1-indexed
            line_end=i,
            pattern_type="blockquote",
            text=text,
            context=context,
        ))

    return candidates


def scan_emdashes(filepath: Path, lines: list[str]) -> list[SlopCandidate]:
    """Find em-dashes (SD-319 violation)."""
    candidates = []
    for i, line in enumerate(lines):
        if EM_DASH in line:
            ctx_start = max(0, i - 1)
            ctx_end = min(len(lines), i + 2)
            context = "\n".join(lines[ctx_start:ctx_end])

            candidates.append(SlopCandidate(
                file=str(filepath),
                line=i + 1,
                line_end=i + 1,
                pattern_type="emdash",
                text=line.strip(),
                context=context,
            ))
    return candidates


def scan_epigrams(filepath: Path, lines: list[str]) -> list[SlopCandidate]:
    """Find epigrammatic closure patterns - short punchy sentences at paragraph end."""
    candidates = []
    epigram_re = re.compile(
        r'^[A-Z][A-Za-z\s]{2,40}(?:is|are|creates?|defines?|becomes?|enables?|requires?)\s+'
        r'(?:the\s+)?[a-z][a-z\s]{2,30}\.?\s*$'
    )

    for i, line in enumerate(lines):
        stripped = line.strip()
        if not stripped:
            continue
        # Check: short sentence (under 60 chars), at paragraph boundary
        # (next line is blank or end of file), matches [Abstract] [verb] [abstract] pattern
        is_para_end = (i + 1 >= len(lines) or lines[i + 1].strip() == "")
        if is_para_end and 10 < len(stripped) < 60 and epigram_re.match(stripped):
            # Skip if inside a code block
            in_code = False
            for j in range(i):
                if lines[j].strip().startswith("```"):
                    in_code = not in_code
            if in_code:
                continue

            ctx_start = max(0, i - 2)
            ctx_end = min(len(lines), i + 2)
            context = "\n".join(lines[ctx_start:ctx_end])

            candidates.append(SlopCandidate(
                file=str(filepath),
                line=i + 1,
                line_end=i + 1,
                pattern_type="epigram",
                text=stripped,
                context=context,
            ))
    return candidates


def scan_emoji(filepath: Path, lines: list[str]) -> list[SlopCandidate]:
    """Find emoji (SD-319 violation)."""
    # Broad emoji ranges
    emoji_re = re.compile(
        "[\U0001F300-\U0001F9FF\U00002600-\U000027BF\U0001FA00-\U0001FA6F"
        "\U0001FA70-\U0001FAFF\U00002702-\U000027B0\U0000FE0F\U0000200D"
        "\U00002194-\U00002199\U000023E9-\U000023F3\U000025AA-\U000025FE]"
    )
    candidates = []
    for i, line in enumerate(lines):
        if emoji_re.search(line):
            ctx_start = max(0, i - 1)
            ctx_end = min(len(lines), i + 2)
            context = "\n".join(lines[ctx_start:ctx_end])
            candidates.append(SlopCandidate(
                file=str(filepath),
                line=i + 1,
                line_end=i + 1,
                pattern_type="emoji",
                text=line.strip(),
                context=context,
            ))
    return candidates


SCANNERS = {
    "blockquote": scan_blockquotes,
    "emdash": scan_emdashes,
    "epigram": scan_epigrams,
    "emoji": scan_emoji,
}


def scan_directory(root: Path, patterns: list[str], include_historical: bool) -> list[SlopCandidate]:
    """Walk directory tree, scan all .md files."""
    all_candidates = []
    md_files = sorted(root.rglob("*.md"))

    for filepath in md_files:
        rel = filepath.relative_to(root)
        if should_skip(rel, include_historical):
            continue

        try:
            text = filepath.read_text(encoding="utf-8")
        except (UnicodeDecodeError, PermissionError):
            continue

        lines = text.splitlines()

        for pattern_name in patterns:
            scanner = SCANNERS.get(pattern_name)
            if scanner:
                candidates = scanner(filepath, lines)
                # Store relative paths for readability
                for c in candidates:
                    c.file = str(rel)
                all_candidates.extend(candidates)

    return all_candidates


# ---------------------------------------------------------------------------
# Phase 2: LLM classification
# ---------------------------------------------------------------------------

CLASSIFY_SYSTEM = """You are a slop detector for a software engineering project's documentation.

"Slop" means AI-generated text that sounds authoritative but adds no information content.
Common patterns:
- Decorative blockquotes with no attribution (epigrammatic closure)
- Em-dashes (project bans them, SD-319)
- Emoji (project bans them, SD-319)
- Sentences that perform seriousness without delivering substance (epistemic theatre)
- Short punchy abstract-noun sentences at paragraph end ("Detection is the intervention.")

Classification rules:
- KILL: No information content, no attribution, purely decorative AI slop
- TRIM: Mixed - has functional content but wrapped in decorative phrasing. State what to keep.
- KEEP: Functional instruction, factual metadata, attributed quote with source, or mission statement
- SKIP: Not slop - false positive from the regex scan

For each candidate, respond with a JSON object:
{"verdict": "KILL|TRIM|KEEP|SKIP", "reason": "1 sentence why", "confidence": 0.0-1.0}
"""


def classify_batch(candidates: list[SlopCandidate]) -> list[SlopCandidate]:
    """Send candidates to claude-haiku-4-5 for classification."""
    try:
        import anthropic
    except ImportError:
        print("ERROR: anthropic package required for LLM classification", file=sys.stderr)
        sys.exit(1)

    api_key = os.environ.get("ANTHROPIC_API_KEY")
    if not api_key:
        print("ERROR: ANTHROPIC_API_KEY not set", file=sys.stderr)
        sys.exit(1)

    client = anthropic.Anthropic(api_key=api_key)

    # Batch into groups of 10 to manage context
    batch_size = 10
    for batch_start in range(0, len(candidates), batch_size):
        batch = candidates[batch_start:batch_start + batch_size]

        user_msg = "Classify each candidate. Respond with a JSON array of objects, one per candidate.\n\n"
        for idx, c in enumerate(batch):
            user_msg += f"--- Candidate {idx} ---\n"
            user_msg += f"File: {c.file}:{c.line}\n"
            user_msg += f"Type: {c.pattern_type}\n"
            user_msg += f"Text: {c.text}\n"
            user_msg += f"Context:\n{c.context}\n\n"

        try:
            response = client.messages.create(
                model="claude-haiku-4-5-20250514",
                max_tokens=2048,
                system=CLASSIFY_SYSTEM,
                messages=[{"role": "user", "content": user_msg}],
            )

            content = response.content[0].text
            # Extract JSON array from response
            # Handle cases where model wraps in markdown code block
            content = content.strip()
            if content.startswith("```"):
                content = re.sub(r'^```\w*\n?', '', content)
                content = re.sub(r'\n?```$', '', content)
                content = content.strip()

            results = json.loads(content)

            for idx, result in enumerate(results):
                if idx < len(batch):
                    batch[idx].verdict = result.get("verdict", "SKIP")
                    batch[idx].reason = result.get("reason", "")
                    batch[idx].confidence = result.get("confidence", 0.0)

        except Exception as e:
            print(f"WARNING: LLM classification failed for batch: {e}", file=sys.stderr)
            for c in batch:
                c.verdict = "SKIP"
                c.reason = f"LLM error: {e}"
                c.confidence = 0.0

    return candidates


# ---------------------------------------------------------------------------
# Phase 3: Interactive keyboard muster
# ---------------------------------------------------------------------------

VERDICT_COLORS = {
    "KILL": "\033[91m",   # red
    "TRIM": "\033[93m",   # yellow
    "KEEP": "\033[92m",   # green
    "SKIP": "\033[90m",   # grey
}
RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"


def getch() -> str:
    """Read a single character from stdin without echo."""
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = sys.stdin.read(1)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return ch


def display_candidate(idx: int, total: int, c: SlopCandidate):
    """Display a single candidate for review."""
    color = VERDICT_COLORS.get(c.verdict, "")

    print(f"\n{'=' * 72}")
    print(f" [{idx + 1}/{total}]  {BOLD}{c.file}:{c.line}{RESET}  ({c.pattern_type})")
    print(f"{'=' * 72}")
    print()

    # Show the text
    for line in c.text.split("\n"):
        print(f"  {DIM}|{RESET} {line}")
    print()

    # Show context (dimmed)
    print(f"  {DIM}Context:{RESET}")
    for line in c.context.split("\n"):
        print(f"  {DIM}  {line}{RESET}")
    print()

    # Show LLM verdict
    print(f"  LLM verdict: {color}{BOLD}{c.verdict}{RESET}  ({c.confidence:.0%})")
    print(f"  Reason: {c.reason}")
    print()
    print(f"  {BOLD}[k]{RESET} KILL  {BOLD}[t]{RESET} TRIM  {BOLD}[s]{RESET} SKIP/KEEP  {BOLD}[Enter]{RESET} accept default  {BOLD}[q]{RESET} quit")


def interactive_muster(candidates: list[SlopCandidate]) -> list[dict]:
    """Walk through candidates one at a time, single keypress decisions."""
    decisions = []
    actionable = [c for c in candidates if c.verdict in ("KILL", "TRIM")]
    skippable = [c for c in candidates if c.verdict in ("KEEP", "SKIP")]

    print(f"\n{BOLD}slopmop muster{RESET}")
    print(f"  {len(candidates)} candidates total")
    print(f"  {len(actionable)} actionable (KILL/TRIM)")
    print(f"  {len(skippable)} skipped (KEEP/SKIP)")
    print(f"\n  Showing actionable items. Press Enter to accept LLM default.")
    print(f"  Press any key to begin...")
    getch()

    for idx, c in enumerate(actionable):
        display_candidate(idx, len(actionable), c)

        while True:
            ch = getch()
            if ch == '\r' or ch == '\n':  # Enter = accept default
                decision = c.verdict
                break
            elif ch == 'k':
                decision = "KILL"
                break
            elif ch == 't':
                decision = "TRIM"
                break
            elif ch == 's':
                decision = "KEEP"
                break
            elif ch == 'q':
                print("\n\nAborted.")
                return decisions

        color = VERDICT_COLORS.get(decision, "")
        print(f"\n  -> {color}{BOLD}{decision}{RESET}")

        decisions.append({
            "file": c.file,
            "line": c.line,
            "pattern": c.pattern_type,
            "llm_verdict": c.verdict,
            "human_verdict": decision,
            "reason": c.reason,
            "text": c.text[:80],
        })

    # Summary
    kills = sum(1 for d in decisions if d["human_verdict"] == "KILL")
    trims = sum(1 for d in decisions if d["human_verdict"] == "TRIM")
    keeps = sum(1 for d in decisions if d["human_verdict"] == "KEEP")
    overrides = sum(1 for d in decisions if d["human_verdict"] != d["llm_verdict"])

    print(f"\n{'=' * 72}")
    print(f" {BOLD}Muster complete{RESET}")
    print(f"  KILL: {kills}  TRIM: {trims}  KEEP: {keeps}")
    print(f"  LLM overrides: {overrides}")
    print(f"{'=' * 72}")

    return decisions


# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

def write_tsv(decisions: list[dict], outpath: Path):
    """Write decisions to TSV."""
    with open(outpath, "w") as f:
        f.write("date\tfile\tline\tpattern\tllm_verdict\thuman_verdict\treason\ttext\n")
        date = datetime.now(timezone.utc).strftime("%Y-%m-%d")
        for d in decisions:
            text = d["text"].replace("\t", " ").replace("\n", " ")[:80]
            reason = d["reason"].replace("\t", " ").replace("\n", " ")
            f.write(f"{date}\t{d['file']}\t{d['line']}\t{d['pattern']}\t"
                    f"{d['llm_verdict']}\t{d['human_verdict']}\t{reason}\t{text}\n")
    print(f"\nDecisions written to {outpath}")


def print_report(candidates: list[SlopCandidate]):
    """Print non-interactive report."""
    by_verdict = {}
    for c in candidates:
        by_verdict.setdefault(c.verdict, []).append(c)

    print(f"\n{'=' * 72}")
    print(f" slopmop report - {len(candidates)} candidates")
    print(f"{'=' * 72}")

    for verdict in ["KILL", "TRIM", "KEEP", "SKIP"]:
        items = by_verdict.get(verdict, [])
        if not items:
            continue
        color = VERDICT_COLORS.get(verdict, "")
        print(f"\n{color}{BOLD}{verdict}{RESET} ({len(items)})")
        print(f"{'-' * 40}")
        for c in items:
            text_preview = c.text.replace("\n", " ")[:60]
            print(f"  {c.file}:{c.line}  ({c.pattern_type})")
            print(f"    {DIM}{text_preview}{RESET}")
            if c.reason:
                print(f"    {c.reason}")
            print()


def print_scan(candidates: list[SlopCandidate]):
    """Print scan-only output (no LLM)."""
    print(f"\n{'=' * 72}")
    print(f" slopmop scan - {len(candidates)} candidates")
    print(f"{'=' * 72}")

    by_type = {}
    for c in candidates:
        by_type.setdefault(c.pattern_type, []).append(c)

    for ptype, items in sorted(by_type.items()):
        print(f"\n{BOLD}{ptype}{RESET} ({len(items)})")
        print(f"{'-' * 40}")
        for c in items:
            text_preview = c.text.replace("\n", " ")[:60]
            print(f"  {c.file}:{c.line}")
            print(f"    {DIM}{text_preview}{RESET}")
            print()


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="slopmop",
        description="Scan markdown for AI slop and muster findings for keyboard-first decisioning.",
    )
    parser.add_argument("command", choices=["scan", "review", "report"],
                        help="scan (no LLM), review (interactive), report (non-interactive)")
    parser.add_argument("path", nargs="?", default=".",
                        help="directory to scan (default: current directory)")
    parser.add_argument("--include-historical", action="store_true",
                        help="include files in archive/historical dirs")
    parser.add_argument("--pattern", default="blockquote,emdash,epigram,emoji",
                        help="comma-separated pattern types (default: all)")
    parser.add_argument("--out", type=str, default=None,
                        help="write decisions to TSV file")

    args = parser.parse_args()

    root = Path(args.path).resolve()
    if not root.is_dir():
        print(f"ERROR: {root} is not a directory", file=sys.stderr)
        sys.exit(1)

    patterns = [p.strip() for p in args.pattern.split(",")]
    invalid = [p for p in patterns if p not in SCANNERS]
    if invalid:
        print(f"ERROR: unknown patterns: {invalid}. Valid: {list(SCANNERS.keys())}", file=sys.stderr)
        sys.exit(1)

    # Phase 1: Scan
    print(f"Scanning {root} for patterns: {', '.join(patterns)}...")
    candidates = scan_directory(root, patterns, args.include_historical)
    print(f"Found {len(candidates)} candidates.")

    if not candidates:
        print("No slop candidates found. Clean.")
        return

    if args.command == "scan":
        print_scan(candidates)
        return

    # Phase 2: LLM classify
    print("Classifying with claude-haiku-4-5...")
    candidates = classify_batch(candidates)

    if args.command == "report":
        print_report(candidates)
        if args.out:
            decisions = [{"file": c.file, "line": c.line, "pattern": c.pattern_type,
                         "llm_verdict": c.verdict, "human_verdict": c.verdict,
                         "reason": c.reason, "text": c.text[:80]} for c in candidates]
            write_tsv(decisions, Path(args.out))
        return

    if args.command == "review":
        # Phase 3: Interactive muster
        decisions = interactive_muster(candidates)
        if args.out and decisions:
            write_tsv(decisions, Path(args.out))
        elif decisions:
            # Default output path
            default_out = Path("data/slopmop") / f"muster-{datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}.tsv"
            default_out.parent.mkdir(parents=True, exist_ok=True)
            write_tsv(decisions, default_out)


if __name__ == "__main__":
    main()
