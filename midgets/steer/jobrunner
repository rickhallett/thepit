#!/usr/bin/env python3
"""
jobrunner — midget job server.

Watches /opt/jobs/incoming/ for job YAML files.
For each job: reads the spec, executes via drive (tmux + sentinel),
writes structured result YAML to /opt/jobs/done/.

Job YAML format (incoming):
  job_id: <str>
  created: <iso8601>
  role: <str>           # which crew role (informational)
  task: shell_command   # task type
  context:
    cmd: <str>          # command to execute
  timeout: <int>        # seconds

Result YAML format (done):
  job_id: <str>
  completed: <iso8601>
  role: <str>
  exit_code: <int>
  verdict: pass|fail
  output: <str>
  summary: <str>

Usage:
  jobrunner                       watch loop (runs until killed)
  jobrunner --once                process one job from incoming/ and exit
  jobrunner --job <path>          process a specific job file and exit
  jobrunner --status              show pending/done counts
"""

import argparse
import json
import os
import subprocess
import sys
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path

import yaml

JOBS_DIR = Path(os.environ.get("MIDGET_JOBS_DIR", "/tmp/jobs"))
INCOMING = JOBS_DIR / "incoming"
DONE = JOBS_DIR / "done"
DRIVE = Path("/opt/steer/drive")
POLL_INTERVAL = 0.5  # seconds between incoming/ scans


def now_iso() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def drive(*args, capture=True):
    """Run a drive command, return (returncode, stdout)."""
    cmd = [str(DRIVE)] + list(args)
    result = subprocess.run(cmd, capture_output=capture, text=True)
    return result.returncode, result.stdout.strip()


def execute_shell_command(job: dict) -> dict:
    """Execute a shell_command job via drive + sentinel protocol."""
    cmd = job.get("context", {}).get("cmd", "")
    timeout = int(job.get("timeout", 60))
    session = f"job-{job['job_id'][:8]}"

    if not cmd:
        return {
            "exit_code": 1,
            "output": "",
            "summary": "no cmd in job context",
        }

    # Create session
    rc, out = drive("session", "create", session, "--json")
    if rc != 0:
        return {
            "exit_code": 1,
            "output": out,
            "summary": f"session create failed: {out}",
        }

    try:
        # Run command with sentinel
        rc, result_json = drive("run", session, cmd, "--timeout", str(timeout), "--json")
        try:
            result = json.loads(result_json)
            exit_code = result.get("exit_code", rc)
            output = result.get("output", "")
        except (json.JSONDecodeError, ValueError):
            exit_code = rc
            output = result_json

        return {
            "exit_code": exit_code,
            "output": output,
            "summary": f"Command completed with exit {exit_code}",
        }
    finally:
        drive("session", "kill", session, "--json")


TASK_HANDLERS = {
    "shell_command": execute_shell_command,
}


def process_job(job_path: Path) -> dict:
    """Read, execute, and return result dict for a single job file."""
    with open(job_path) as f:
        job = yaml.safe_load(f)

    task = job.get("task", "")
    handler = TASK_HANDLERS.get(task)

    if handler is None:
        execution = {
            "exit_code": 1,
            "output": "",
            "summary": f"unknown task type: {task}",
        }
    else:
        try:
            execution = handler(job)
        except Exception as e:
            execution = {
                "exit_code": 1,
                "output": "",
                "summary": f"handler raised: {e}",
            }

    exit_code = execution.get("exit_code", 1)
    return {
        "job_id": job.get("job_id", str(uuid.uuid4())),
        "completed": now_iso(),
        "role": job.get("role", "worker"),
        "task": task,
        "exit_code": exit_code,
        "verdict": "pass" if exit_code == 0 else "fail",
        "output": execution.get("output", ""),
        "summary": execution.get("summary", ""),
    }


def write_result(result: dict) -> Path:
    """Write result YAML to done/ directory (atomic via temp + rename)."""
    DONE.mkdir(parents=True, exist_ok=True)
    out_path = DONE / f"{result['job_id']}.yaml"
    tmp_path = DONE / f".{result['job_id']}.yaml.tmp"
    with open(tmp_path, "w") as f:
        yaml.dump(result, f, default_flow_style=False, sort_keys=False)
    tmp_path.rename(out_path)  # atomic on same filesystem
    return out_path


def _emit(data, as_json=False):
    if as_json:
        print(json.dumps(data, indent=2))
    else:
        for k, v in data.items():
            print(f"{k}: {v}")


def cmd_watch(args):
    """Watch incoming/ and process jobs as they arrive."""
    INCOMING.mkdir(parents=True, exist_ok=True)
    DONE.mkdir(parents=True, exist_ok=True)
    processed = set()

    print(f"jobrunner watching {INCOMING} ...", flush=True)
    while True:
        for job_file in sorted(INCOMING.glob("*.yaml")):
            if job_file in processed:
                continue
            # Atomic acquisition: rename to .processing
            claimed = job_file.with_suffix(".processing")
            try:
                os.rename(job_file, claimed)
            except (FileNotFoundError, OSError):
                continue
            processed.add(job_file)
            print(f"  processing {claimed.name}", flush=True)
            try:
                result = process_job(claimed)
                out_path = write_result(result)
                print(f"  -> {result['verdict']} ({result['summary']}) -> {out_path.name}", flush=True)
                claimed.unlink()
            except Exception as e:
                print(f"  ERROR: {e}", flush=True)
        time.sleep(POLL_INTERVAL)


def cmd_once(args):
    """Process one job from incoming/ and exit.

    Uses atomic rename to acquire a job — prevents contention when
    multiple workers (C3 swarm) race for the same incoming/ directory.
    os.rename() is atomic on Linux; if another worker already grabbed
    the file, FileNotFoundError or OSError fires and we try the next one.
    """
    INCOMING.mkdir(parents=True, exist_ok=True)
    DONE.mkdir(parents=True, exist_ok=True)

    jobs = sorted(INCOMING.glob("*.yaml"))
    if not jobs:
        print("no jobs in incoming/", file=sys.stderr)
        return 1

    # Atomic acquisition: rename to .processing
    job_file = None
    claimed = None
    for candidate in jobs:
        claimed = candidate.with_suffix(".processing")
        try:
            os.rename(candidate, claimed)
            job_file = claimed
            break
        except (FileNotFoundError, OSError):
            # Another worker grabbed it first — try next
            continue

    if job_file is None:
        print("no jobs acquired (all claimed by other workers)", file=sys.stderr)
        return 1

    print(f"processing {job_file.name}", flush=True)
    result = process_job(job_file)
    out_path = write_result(result)
    job_file.unlink()

    _emit(result, as_json=args.json)
    print(f"result written to {out_path}", flush=True)
    return 0 if result["exit_code"] == 0 else 1


def cmd_job(args):
    """Process a specific job file and exit."""
    job_path = Path(args.job)
    if not job_path.exists():
        print(f"ERROR: {job_path} not found", file=sys.stderr)
        return 1

    DONE.mkdir(parents=True, exist_ok=True)
    result = process_job(job_path)
    out_path = write_result(result)

    _emit(result, as_json=args.json)
    print(f"result written to {out_path}", flush=True)
    return 0 if result["exit_code"] == 0 else 1


def cmd_status(args):
    """Show pending/done counts."""
    INCOMING.mkdir(parents=True, exist_ok=True)
    DONE.mkdir(parents=True, exist_ok=True)
    pending = len(list(INCOMING.glob("*.yaml")))
    done = len(list(DONE.glob("*.yaml")))
    _emit({"pending": pending, "done": done}, as_json=args.json)
    return 0


def build_parser():
    parser = argparse.ArgumentParser(
        prog="jobrunner",
        description="midget job server: receive job YAML, execute, write result YAML",
    )
    parser.add_argument("--json", action="store_true")
    sub = parser.add_subparsers(dest="command")

    # watch (default)
    sub.add_parser("watch", help="Watch incoming/ loop (default)")

    # once
    sub.add_parser("once", help="Process one job and exit")

    # job <path>
    p_job = sub.add_parser("job", help="Process a specific job file")
    p_job.add_argument("job", help="Path to job YAML")

    # status
    sub.add_parser("status", help="Show pending/done counts")

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    cmd = getattr(args, "command", None) or "watch"

    if cmd == "watch":
        sys.exit(cmd_watch(args))
    elif cmd == "once":
        sys.exit(cmd_once(args))
    elif cmd == "job":
        sys.exit(cmd_job(args))
    elif cmd == "status":
        sys.exit(cmd_status(args))
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
